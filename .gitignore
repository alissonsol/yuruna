# Project tree (cloned per cycle from test.config.yml's repositories.projectUrl)
project/

# All harness runtime state lives under test/status/<subdir>/ -- one
# umbrella rule covers every subdirectory the runner creates:
#   test/status/runtime/    pids, status.json, control flags,
#                           ipaddresses.txt, caching-proxy.txt, server.err,
#                           yuruna-caching-proxy.yml, host.uuid,
#                           .status-service.ps1, etc. See Test.YurunaDir.psm1
#                           -- $env:YURUNA_RUNTIME_DIR defaults here so the
#                           status server can serve /runtime/<name>.
#   test/status/log/        HTML transcripts, OCR debug artifacts, failure
#                           screenshots. See Test.YurunaDir.psm1 --
#                           $env:YURUNA_LOG_DIR defaults here so the status
#                           server can serve /log/<name>.
#   test/status/perf/       JSONL perf rows + content-addressed host/guest
#                           dump sidecars.
#   test/status/extension/  Per-extension runtime state. Today:
#                           authentication/vault.yml, vault.lock,
#                           events.log (plaintext); notification/
#                           transports.yml (Resend API key).
#   test/status/captures/   Sequence debug screenshots
#                           (sequences/*.png) and per-cycle training
#                           captures (training/<guest>__<cp>.png). The
#                           committed reference PNGs live in
#                           test/screenshots/<guest>/reference/ -- those
#                           ARE source content and stay tracked.
#   test/status/ssh/        Generated per-host ed25519 key pair injected
#                           into every guest's cloud-init.
# Only the committed UI files at the test/status/ root (index.html,
# hostinfo.html, test.config.html, yuruna.common.css, yuruna.common.js,
# status.json.template) and the .gitkeep stay tracked.
test/status/*/

# Legacy paths from before the status reorg. The umbrella rule above
# catches the new locations; these explicit rules cover the OLD paths so
# an upgrade with leftover files does not surface them as untracked.
test/status/track/
test/extension/authentication/vault.lock
test/extension/authentication/vault.yml
test/extension/notification/notification.transports.yml
test/screenshots/*/captures/
test/sequences/captures/

