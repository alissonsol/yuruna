# CLAUDE.md is intentionally tracked in yurunadev (private). When copying
# yurunadev into the public yuruna repository, remove it from the public
# commits -- see the reminder at the top of CLAUDE.md.

# Yuruna test harness SSH keys are generated per-host on first run and now
# live under test/status/ssh/ (covered by the umbrella status-subdirs
# ignore below). The legacy test/.ssh/ path is kept here so that an
# upgrade with a stale per-host key folder doesn't suddenly appear as
# untracked in `git status`.
test/.ssh/

