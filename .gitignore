# Test configuration (contains credentials)
test/test-config.json
test/test.config.yml
test/test.config.yml.backup

# Per-cycle authentication vault and lock sentinel (test/extension/authentication/).
# Wiped on cycle success; left in place on failure for debugging. Plaintext.
test/extension/authentication/vault.lock
test/extension/authentication/vault.yml

# Notification transports + subscribers (test/extension/notification/).
# Template ships in-tree; live config is gitignored because it carries Resend API keys.
test/extension/notification/notification.transports.yml

# Per-cycle authentication event log (JSON-lines; never logs password values).
test/status/track/extension/

# Project tree (cloned per cycle from test.config.yml's repositories.projectUrl)
project/

# Runtime tracking files (pids, status.json, control flags, ipaddresses.txt,
# caching-proxy.txt, server.err, .status-server.ps1, etc.)
# See Test.TrackDir.psm1 — $env:YURUNA_TRACK_DIR defaults here so the status
# server can serve /track/<name>.
test/status/track/*
!test/status/track/.gitkeep

# Test run logs: HTML transcripts, OCR debug artifacts, failure screenshots.
# See Test.LogDir.psm1 — $env:YURUNA_LOG_DIR defaults here so the status
# server can serve /log/<name>.
test/status/log/*
!test/status/log/.gitkeep

# Training screenshots (captures are runtime, reference PNGs are committed)
test/screenshots/*/captures/

# Sequence debug screenshots (captured at runtime)
test/sequences/captures/

