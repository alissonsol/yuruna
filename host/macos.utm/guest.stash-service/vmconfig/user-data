#cloud-config
# --- See https://yuruna.link/vmconfig
# Minimal cloud-init for the stash-service VM. See the Hyper-V sibling
# (host/windows.hyper-v/guest.stash-service/vmconfig/user-data) for the
# rationale -- this file is hand-maintained as a parallel copy per
# feedback_cache_userdata_three_platforms.md.
hostname: yuruna-stash-service
users:
  - name: yuruna
    gecos: yuruna stash-service user
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    ssh_authorized_keys:
      - SSH_AUTHORIZED_KEY_PLACEHOLDER
chpasswd:
  expire: false
  users:
    - name: yuruna
      password: PASSWORD_PLACEHOLDER
      type: text
ssh_pwauth: true
