#vim:syntax=yaml
# --- REGION: https://yuruna.link/vmconfig/caching-proxy
# --- REGION: https://yuruna.link/vmconfig/caching-proxy#squid-cache-hostname-vs-template-name
hostname: yuruna-caching-proxy
# --- REGION: https://yuruna.link/vmconfig/caching-proxy#users-replace-cloud-image-default-with-yuruna
users:
  - name: yuruna
    gecos: yuruna debug user
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    ssh_authorized_keys:
      - SSH_AUTHORIZED_KEY_PLACEHOLDER
chpasswd:
  expire: false
  users:
    - name: yuruna
      password: PASSWORD_PLACEHOLDER
      type: text
ssh_pwauth: true
# --- REGION: https://yuruna.link/vmconfig/caching-proxy#grafana-apt-repo-inline-gpg-key
apt:
  sources:
    grafana.list:
      source: "deb https://apt.grafana.com stable main"
      key: |
