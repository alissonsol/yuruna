#cloud-config
#vim:syntax=yaml
users:
  - default
# ssh_authorized_keys at top level: avoids cloud-init silently merging/dropping
# the key when the username matches the distro-default user (ec2-user).
ssh_authorized_keys:
  - SSH_AUTHORIZED_KEY_PLACEHOLDER
chpasswd:
  list: |
    ec2-user:amazonlinux
# In the above line, do not add any spaces after 'ec2-user:'.
ssh_pwauth: true

# --- System: denylist hv_balloon to prevent console messages ---
write_files:
  - path: /etc/modprobe.d/denylist-hv-balloon.conf
    content: |
      blacklist hv_balloon
    permissions: '0644'

runcmd:
  # --- System: unload hv_balloon if already loaded ---
  - rmmod hv_balloon 2>/dev/null || true
  # --- SSH: ensure sshd is enabled and running for test-harness SSH access ---
  - systemctl enable --now sshd || true
  # --- GNOME: auto-open terminal on login ---
  - mkdir -p /etc/xdg/autostart
  - |
    cat > /etc/xdg/autostart/open-terminal.desktop << 'DESKTOP'
    [Desktop Entry]
    Type=Application
    Name=Open Terminal
    Exec=ptyxis --new-window
    X-GNOME-Autostart-enabled=true
    NoDisplay=true
    DESKTOP
  # --- Yuruna host coordinates: written for the dev iteration loop ---
  # New-VM.ps1 substitutes the placeholders below at provision time.
  # See Test-YurunaHost.ps1 for the in-guest probe that verifies these
  # coordinates are still valid after a host reboot.
  - mkdir -p /etc/yuruna
  - |
    cat > /etc/yuruna/host.env << 'EOF'
    YURUNA_HOST_IP=YURUNA_HOST_IP_PLACEHOLDER
    YURUNA_HOST_PORT=YURUNA_HOST_PORT_PLACEHOLDER
    EOF
  - bash -c 'grep -q yuruna-host /etc/hosts || echo "YURUNA_HOST_IP_PLACEHOLDER yuruna-host" >> /etc/hosts'
  # --- wget no_proxy: belt-and-braces for the host status-server probe ---
  # If the squid-cache proxy URL ever leaks into wget's environment, an
  # in-guest fetch-and-execute.sh that lacks --no-proxy would route the
  # /livecheck probe through the cache, which cannot reach the host's
  # private NAT address, and silently fall through to GitHub.
  - |
    cat >> /etc/wgetrc << 'EOF'
    no_proxy = YURUNA_HOST_IP_PLACEHOLDER
    EOF
  # --- Network: download fetch-and-execute utility ---
  # Try the host status server first (fast, local, devloop-friendly)
  # and fall back to raw.githubusercontent.com if it is not reachable.
  - mkdir -p /automation
  - |
    wget --no-cache --timeout=5 -O /automation/fetch-and-execute.sh "http://YURUNA_HOST_IP_PLACEHOLDER:YURUNA_HOST_PORT_PLACEHOLDER/yuruna-repo/automation/fetch-and-execute.sh" || \
    wget --no-cache -O /automation/fetch-and-execute.sh "https://raw.githubusercontent.com/alissonsol/yuruna/refs/heads/main/automation/fetch-and-execute.sh"
  - chmod +x /automation/fetch-and-execute.sh
  # --- Network: timezone detection via IP geolocation and NTP ---
  - timedatectl set-ntp true
  - bash -c 'command -v curl >/dev/null 2>&1 && TZ=$(curl -s --max-time 5 http://ip-api.com/line?fields=timezone) && [ -n "$TZ" ] && timedatectl set-timezone "$TZ" || echo "Yuruna => Timezone sync failed (check curl, network, or API)" >&2'
