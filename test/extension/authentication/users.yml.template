# yaml-language-server: $schema=../../schemas/users.schema.yml

# Yuruna authentication: logical-username -> corporate-identity mapping.
#
# Default behavior (all corporate.* / vaultKey / localOsPasswordRef
# fields empty) keeps the harness operating exactly as before: each
# logical user is its own local OS account with a vault-auto-generated
# password.
#
# To integrate with a corporate directory (AD / Entra / SSSD-against-
# LDAP / ...):
#   1. Populate `corporate.domain` + `corporate.sam` (or `corporate.upn`)
#      so sequence-login steps render the right identity via the
#      ${loginUser} substitution.
#   2. Set `vaultKey` to the vault.yml entry that holds the corporate
#      password (e.g. "corp.alisson.sol"); pre-populate that vault
#      entry manually. Test-Config.ps1 blocks the cycle if the entry
#      is missing -- the vault never auto-generates for a populated
#      vaultKey.
#   3. Leave `localOsPasswordRef` empty unless you specifically want
#      the local OS account on the test VM to share its password with
#      the corporate identity (default is decoupled: the local account
#      receives a fresh auto-gen secret that nobody needs to know).
#
# Add new entries here whenever a sequence introduces a new logical
# username. With `strict: true` (recommended), Test-Config.ps1 fails
# the cycle on the first undeclared name -- this is intentional, so
# the production AD path stays exercised on every dev cycle.

strict: true

users:

  # Default Yuruna test users -- one per bundled guest OS. Out of the
  # box, no corporate mapping; cloud-init creates these as local OS
  # accounts with vault-auto-generated passwords (today's behavior).

  yuuser24:
    localOsUser: yuuser24
    corporate:   { domain: "", sam: "", upn: "" }
    vaultKey:           ""
    localOsPasswordRef: ""

  yuuser26:
    localOsUser: yuuser26
    corporate:   { domain: "", sam: "", upn: "" }
    vaultKey:           ""
    localOsPasswordRef: ""

  yauser1:
    localOsUser: yauser1
    corporate:   { domain: "", sam: "", upn: "" }
    vaultKey:           ""
    localOsPasswordRef: ""

  ywuser1:
    localOsUser: ywuser1
    corporate:   { domain: "", sam: "", upn: "" }
    vaultKey:           ""
    localOsPasswordRef: ""

  # The cache-VM (yuruna-caching-proxy) provisioning sequence uses the
  # 'yuruna' logical user. Cross-cycle persistence is owned by
  # Test.CachingProxy (yuruna-caching-proxy.yml under status/runtime/);
  # the entry is declared here so strict mode does not refuse the
  # cycle when a sequence references it.
  yuruna:
    localOsUser: yuruna
    corporate:   { domain: "", sam: "", upn: "" }
    vaultKey:           ""
    localOsPasswordRef: ""

  # Pool push-ingest shared bearer token (Phase 6). NOT a login user: this logical
  # entry exists so the pool-aggregator's POST /ingest write route can be gated by an
  # operator-supplied token. Leave vaultKey EMPTY (default) to keep push DISABLED -- the
  # aggregator then refuses /ingest entirely. To ENABLE push: set vaultKey to a key
  # (e.g. "pool.auth.token"), then run `Set-Password -Username pool-auth-token` once
  # with the shared token. The vault never auto-generates for a populated vaultKey, so
  # the token stays operator-owned; set the SAME token on every pool host AND the proxy.
  pool-auth-token:
    localOsUser: ""
    corporate:   { domain: "", sam: "", upn: "" }
    vaultKey:           ""
    localOsPasswordRef: ""

  # ----------------------------------------------------------------
  # Example: a workload-defined logical user mapped to a corporate AD
  # identity. Uncomment and adapt when a `workload.*.yml` declares
  # `variables.username: webuser`.
  #
  # webuser:
  #   localOsUser: webuser
  #   corporate:
  #     domain: "CORP"
  #     sam:    "alisson.sol"
  #     # upn:  "alisson.sol@corp.example.com"      # alternative form
  #   vaultKey:           "corp.alisson.sol"
  #   localOsPasswordRef: ""                         # decoupled: local
  #                                                  # OS account gets
  #                                                  # auto-gen secret
  # ----------------------------------------------------------------
