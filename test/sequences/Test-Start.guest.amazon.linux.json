{
  "$schema": "Interaction sequence for driving VM installation.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in. Use ${varName} in step parameters.",

  "description": "Amazon Linux: login, change password, run update script, shut down.",
  "variables": {
    "username":    "ec2-user",
    "password":    "amazonlinux",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForText",
      "pattern": "login:",
      "timeoutSeconds": 300,
      "pollSeconds": 6,
      "description": "login:"
    },
    {
      "action": "typeAndEnter",
      "text": "${username}",
      "description": "Enter username"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password:",
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${password}",
      "sensitive": true,
      "description": "Password:"
    },
    {
      "action": "waitForAndEnter",
      "pattern": ["Current password:", "urrent password"],
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${password}",
      "sensitive": true,
      "description": "Current password:"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "New password:",
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "New password:"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Retype new password:",
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Retype new password:"
    },
    {
      "action": "fetchAndExecute",
      "text": "sudo bash /automation/fetch-and-execute.sh vde/guest.amazon.linux/amazon.linux.update.sh",
      "description": "vde/guest.amazon.linux/amazon.linux.update.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 600,
      "waitPollSeconds": 9
    },
    {
      "action": "delay",
      "seconds": 9,
      "description": "Pause before rebooting"
    },
    {
      "action": "typeAndEnter",
      "text": "clear; sudo reboot now",
      "description": "Reboot the VM"
    }
  ]
}
