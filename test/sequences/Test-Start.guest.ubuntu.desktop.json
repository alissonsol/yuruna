{
  "$schema": "Interaction sequence for driving VM installation.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in. Use ${varName} in step parameters.",

  "description": "Ubuntu Desktop: dismiss GRUB menu, confirm desktop installer, wait for install + reboot, then complete first login.",
  "variables": {
    "username":    "ubuntu",
    "password":    "password",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForAndEnter",
      "pattern": "Try or Install Ubuntu",
      "timeoutSeconds": 600,
      "pollSeconds": 6,
      "text": "",
      "description": "Try or Install Ubuntu"
    },
    {
      "action": "delay",
      "seconds": 15,
      "description": "HACK: Delay"
    },    
    {
      "action": "typeAndEnter",
      "text": "",
      "description": "HACK: Enter to dismiss empty screen, if it appears."
    },
    {
      "action": "waitForAndClickButton",
      "label": ["Ready to install"],
      "timeoutSeconds": 600,
      "pollSeconds": 9,
      "description": "Wait for Ready to install dialog"
    },
    {
      "action": "tabsAndEnter",
      "tabCount": 2,
      "delaySeconds": 1,
       "text": "",
      "description": "Tab to Install button and enter"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Not listed?",
      "timeoutSeconds": 3600,
      "pollSeconds": 15,
      "text": "",
      "description": "Not listed?"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password",
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${password}",
      "sensitive": true,
      "description": "Password"
    },
    {
      "action": "waitForAndEnter",
      "pattern": ["Current password", "urrent password"],
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${password}",
      "sensitive": true,
      "description": "Current password"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "New password",
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "New password"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Retype new password",
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Retype new password"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "description": "${username}@${vmName}"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh vde/guest.ubuntu.desktop/ubuntu.desktop.update.sh",
      "description": "ubuntu.desktop.update.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 600,
      "waitPollSeconds": 9
    },
    {
      "action": "typeAndEnter",
      "text": "clear; sudo reboot now",
      "description": "Reboot the VM"
    }
  ]
}
