{
  "$schema": "Interaction sequence for driving VM workload testing.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in. Use ${varName} in step parameters.",

  "description": "Amazon Linux: log in with new password, install the Desktop package group.",
  "variables": {
    "username":    "ec2-user",
    "password":    "amazonlinux",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForText",
      "pattern": "login:",
      "timeoutSeconds": 300,
      "pollSeconds": 6,
      "description": "login:"
    },
    {
      "action": "typeAndEnter",
      "text": "${username}",
      "description": "Enter username"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password:",
      "timeoutSeconds": 30,
      "pollSeconds": 3,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Password:"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 30,
      "pollSeconds": 3,
      "description": "${username}@${vmName}"
    },
    {
      "action": "delay",
      "seconds": 9,
      "description": "Pause before installing Desktop"
    },
    {
      "action": "typeAndEnter",
      "text": "sudo dnf groupinstall -y \"Desktop\"",
      "description": "GUI install"
    },
    {
      "action": "delay",
      "seconds": 15,
      "description": "HACK: scroll login prompt off"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 300,
      "pollSeconds": 6,
      "freshMatch": true,
      "description": "${username}@${vmName}"
    },
    {
      "action": "typeAndEnter",
      "text": "dnf list installed | grep desktop",
      "description": "Show installed desktop packages"
    },
    {
      "action": "delay",
      "seconds": 10,
      "description": "Pause to see output."
    }
  ]
}
