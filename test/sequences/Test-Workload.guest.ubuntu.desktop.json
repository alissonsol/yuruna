{
  "$schema": "Interaction sequence for driving VM workload testing.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in. Use ${varName} in step parameters.",

  "description": "Ubuntu Desktop: log in with new password, install VS Code.",
  "variables": {
    "username":    "ubuntu",
    "password":    "password",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForAndEnter",
      "pattern": "Not listed?",
      "timeoutSeconds": 600,
      "pollSeconds": 6,
      "text": "",
      "description": "Not listed?"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password",
      "timeoutSeconds": 60,
      "pollSeconds": 3,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Password"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "description": "${username}@${vmName}"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh virtual/guest.ubuntu.desktop/ubuntu.desktop.code.sh",
      "description": "ubuntu.desktop.code.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 300,
      "waitPollSeconds": 9
    },
    {
      "action": "typeAndEnter",
      "text": "clear; sudo reboot now",
      "description": "Reboot the VM"
    }
  ]
}
