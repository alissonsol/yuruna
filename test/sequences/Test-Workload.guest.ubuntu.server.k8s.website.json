{
  "$schema": "Interaction sequence for driving VM workload testing.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in. Use ${varName} in step parameters.",

  "description": "Ubuntu Server (with ubuntu-desktop): log in, install Kubernetes, deploy website to localhost cluster, verify HTTP 200. Reuses the guest.ubuntu.desktop workload scripts — ubuntu-desktop behaves identically whichever ISO seeded it.",
  "variables": {
    "username":    "ubuntu",
    "password":    "password",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForAndEnter",
      "pattern": "Not listed?",
      "timeoutSeconds": 600,
      "pollSeconds": 6,
      "text": "",
      "description": "Wait for GDM login screen"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Password (already changed on first login during Test-Start)"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 120,
      "pollSeconds": 6,
      "description": "Wait for shell prompt"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh vde/guest.ubuntu.desktop/ubuntu.desktop.k8s.sh",
      "description": "vde/guest.ubuntu.desktop/ubuntu.desktop.k8s.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 1800,
      "waitPollSeconds": 9
    },
    {
      "action": "typeAndEnter",
      "text": "clear; kubectl get nodes",
      "description": "Check node status"
    },
    {
      "action": "waitForText",
      "pattern": "Ready",
      "timeoutSeconds": 60,
      "pollSeconds": 9,
      "description": "Wait for node to be Ready"
    },
    {
      "action": "typeAndEnter",
      "text": "clear; newgrp docker",
      "description": "Activate docker group for this current session"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh vde/guest.ubuntu.desktop/ubuntu.desktop.workload.k8s.website.sh",
      "description": "vde/guest.ubuntu.desktop/ubuntu.desktop.workload.k8s.website.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 600,
      "waitPollSeconds": 9
    },
    {
      "action": "delay",
      "seconds": 30,
      "description": "Wait for pods to start"
    },
    {
      "action": "typeAndEnter",
      "text": "clear; bash /home/ubuntu/yuruna/test/test-localhost.sh",
      "description": "Check website return code"
    },
    {
      "action": "waitForText",
      "pattern": "200",
      "timeoutSeconds": 120,
      "pollSeconds": 6,
      "description": "Verify HTTP 200 response"
    },
    {
      "action": "typeAndEnter",
      "text": "clear; sudo reboot now",
      "description": "Reboot the VM"
    }
  ]
}
