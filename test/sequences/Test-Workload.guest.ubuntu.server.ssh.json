{
  "$schema": "SSH-driven equivalent of Test-Workload.guest.ubuntu.server.json. Selected automatically when test-config.json has keystrokeMechanism='SSH'.",
  "$actions": "See possible actions in the actions.json file",

  "description": "Ubuntu Server (with ubuntu-desktop, SSH): install VS Code and verify — parallel path to the keystroke sequence.",
  "variables": {
    "username": "ubuntu"
  },
  "steps": [
    {
      "action": "sshWaitReady",
      "timeoutSeconds": 300,
      "pollSeconds": 5,
      "description": "Wait for sshd after reboot"
    },
    {
      "action": "sshExec",
      "command": "whoami && hostname",
      "description": "Smoke test: whoami/hostname"
    },
    {
      "action": "sshFetchAndExecute",
      "command": "/automation/fetch-and-execute.sh virtual/guest.ubuntu.desktop/ubuntu.desktop.code.sh",
      "timeoutSeconds": 1800,
      "description": "ubuntu.desktop.code.sh"
    },
    {
      "action": "sshExec",
      "command": "dpkg -l | grep -i 'code ' || true",
      "allowFailure": true,
      "description": "Show installed VS Code package"
    }
  ]
}
