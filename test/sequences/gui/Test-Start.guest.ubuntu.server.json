{
  "$schema": "Interaction sequence for driving VM installation.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in. Use ${varName} in step parameters.",

  "description": "Ubuntu Server (with ubuntu-desktop): dismiss GRUB, wait for unattended autoinstall + reboot + GDM, complete first login. No Install-button click — subiquity runs hands-off via autoinstall's interactive-sections:[].",
  "variables": {
    "username":    "ubuntu",
    "password":    "password",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForAndEnter",
      "pattern": "Continue with autoinstall?",
      "timeoutSeconds": 600,
      "pollSeconds": 6,
      "text": "yes",
      "description": "Continue with autoinstall?"
    },    
    {
      "action": "waitForAndEnter",
      "pattern": "${vmName} login:",
      "timeoutSeconds": 600,
      "pollSeconds": 15,
      "text": "${username}",
      "sensitive": true,
      "description": "Login:"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password:",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "text": "${password}",
      "sensitive": true,
      "description": "Password"
    },
    {
      "action": "waitForAndEnter",
      "pattern": ["Current password", "urrent password"],
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "text": "${password}",
      "sensitive": true,
      "description": "Current password"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "New password",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "New password"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Retype new password",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Retype new password"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "description": "${username}@${vmName}"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh virtual/guest.ubuntu.server/ubuntu.server.update.sh",
      "description": "ubuntu.server.update.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 600,
      "waitPollSeconds": 9
    },
    {
      "action": "typeAndEnter",
      "text": "clear; sudo reboot now",
      "description": "Reboot the VM"
    }
  ]
}
