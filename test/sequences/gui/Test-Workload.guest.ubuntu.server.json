{
  "$schema": "Interaction sequence for driving VM workload testing.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in.",

  "description": "Ubuntu Server: log in with new password, install VS Code using the guest.ubuntu.server workload scripts.",
  "variables": {
    "username":    "ubuntu",
    "password":    "password",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForAndEnter",
      "pattern": "${vmName} login:",
      "timeoutSeconds": 900,
      "pollSeconds": 6,
      "text": "${username}",
      "sensitive": true,
      "description": "${vmName} login:"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password:",
      "timeoutSeconds": 90,
      "pollSeconds": 6,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Password"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 90,
      "pollSeconds": 6,
      "description": "${username}@${vmName}"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh guest/ubuntu.server/ubuntu.server.code.sh",
      "description": "ubuntu.server.code.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 600,
      "waitPollSeconds": 9
    },
    {
      "action": "typeAndEnter",
      "text": "clear; sudo reboot now",
      "description": "Reboot the VM"
    }
  ]
}
