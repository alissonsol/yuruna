{
  "$schema": "Interaction sequence for driving VM workload testing.",
  "$actions": "See possible actions in the actions.json file",
  "$variables": "Define defaults below. ${vmName}, ${hostType}, ${guestKey} are built-in. Use ${varName} in step parameters.",

  "description": "Ubuntu Server: log in, install Kubernetes, deploy website to localhost cluster, verify HTTP 200. Uses the guest.ubuntu.server workload scripts.",
  "variables": {
    "username":    "ubuntu",
    "password":    "password",
    "newPassword": "belohorizonte"
  },
  "steps": [
    {
      "action": "waitForAndEnter",
      "pattern": "${vmName} login:",
      "timeoutSeconds": 600,
      "pollSeconds": 15,
      "text": "${username}",
      "sensitive": true,
      "description": "Login:"
    },
    {
      "action": "waitForAndEnter",
      "pattern": "Password:",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "text": "${newPassword}",
      "sensitive": true,
      "description": "Password"
    },
    {
      "action": "waitForText",
      "pattern": "${username}@${vmName}",
      "timeoutSeconds": 60,
      "pollSeconds": 6,
      "description": "${username}@${vmName}"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh virtual/guest.ubuntu.server/ubuntu.server.k8s.sh",
      "description": "ubuntu.server.k8s.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 1800,
      "waitPollSeconds": 9
    },
    {
      "action": "typeAndEnter",
      "text": "clear; kubectl get nodes",
      "description": "Check node status"
    },
    {
      "action": "waitForText",
      "pattern": "Ready",
      "timeoutSeconds": 60,
      "pollSeconds": 9,
      "description": "Ready"
    },
    {
      "action": "typeAndEnter",
      "text": "clear; newgrp docker",
      "description": "Activate docker group"
    },
    {
      "action": "fetchAndExecute",
      "text": "/automation/fetch-and-execute.sh virtual/guest.ubuntu.server/ubuntu.server.workload.k8s.website.sh",
      "description": "ubuntu.server.workload.k8s.website.sh",
      "waitPattern": "FETCHED AND EXECUTED:",
      "waitTimeoutSeconds": 600,
      "waitPollSeconds": 9
    },
    {
      "action": "delay",
      "seconds": 30,
      "description": "Wait for pods to start"
    },
    {
      "action": "typeAndEnter",
      "text": "clear; /automation/fetch-and-execute.sh test/test-localhost.sh",
      "description": "Check website return code"
    },
    {
      "action": "waitForText",
      "pattern": "200 OK",
      "timeoutSeconds": 120,
      "pollSeconds": 6,
      "description": "200"
    },
    {
      "action": "typeAndEnter",
      "text": "clear; sudo reboot now",
      "description": "Reboot the VM"
    }
  ]
}
