{
  "$schema": "SSH-driven equivalent of Test-Workload.guest.ubuntu.desktop.k8s.website.json. Selected automatically when test-config.json has keystrokeMechanism='SSH'.",
  "$actions": "See possible actions in the actions.json file",

  "description": "Ubuntu Desktop (SSH): install Kubernetes, deploy website to localhost cluster, verify HTTP 200 - parallel path to the keystroke sequence.",
  "variables": {
    "username": "ubuntu"
  },
  "steps": [
    {
      "action": "sshWaitReady",
      "timeoutSeconds": 300,
      "pollSeconds": 5,
      "description": "Wait for sshd + authorized_keys"
    },
    {
      "action": "sshExec",
      "command": "whoami && hostname",
      "description": "Smoke test: whoami/hostname"
    },
    {
      "action": "sshFetchAndExecute",
      "command": "/automation/fetch-and-execute.sh virtual/guest.ubuntu.desktop/ubuntu.desktop.k8s.sh",
      "timeoutSeconds": 1800,
      "description": "ubuntu.desktop.k8s.sh"
    },
    {
      "action": "sshExec",
      "command": "kubectl get nodes | grep -w Ready",
      "timeoutSeconds": 120,
      "description": "Verify at least one node Ready"
    },
    {
      "action": "sshFetchAndExecute",
      "command": "/automation/fetch-and-execute.sh virtual/guest.ubuntu.desktop/ubuntu.desktop.workload.k8s.website.sh",
      "timeoutSeconds": 1800,
      "description": "desktop.workload.k8s.website.sh"
    },
    {
      "action": "delay",
      "seconds": 30,
      "description": "Pause for pods to start"
    },
    {
      "action": "sshExec",
      "command": "bash /home/ubuntu/yuruna/test/test-localhost.sh 2>&1 | tee /tmp/test-localhost.out; grep -q 200 /tmp/test-localhost.out",
      "timeoutSeconds": 120,
      "description": "Check HTTP 200 in test output"
    }
  ]
}
