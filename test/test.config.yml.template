guestSequence:
  - guest.amazon.linux.2023
  - guest.ubuntu.server.24
  - guest.ubuntu.server.26
logLevel: Information
notification:
  failuresBeforeAlert: 2
  successesBeforeRearm: 5
repositories:
  frameworkUrl: https://github.com/alissonsol/yuruna
  projectUrl: https://github.com/alissonsol/yuruna-project
statusService:
  isEnabled: true
  port: 8080
testCycle:
  cycleDelaySeconds: 300
  recentDisplayCount: 30
  shouldStopOnFailure: false
  stepTimeoutMinutes: 45
  # Default-off self-heal. When true, the outer failure-pause ends early
  # (auto-retry) for a clearly-safe transient failure class (wait_timeout,
  # instrumentation_failure, network_timeout, host_io_blocked) instead of
  # waiting up to the failure-pause cap for a human commit. Capped per
  # consecutive-failure streak so a deterministic failure still escalates to
  # the normal wait-for-human pause after this many auto-retries.
  autoRemediationEnabled: false
  autoRemediationMaxAttemptsPerCycle: 2
vmCommunication:
  characterDelayMs: 20
  keystrokeMechanism: GUI
  pollSeconds: 5
  timeoutSeconds: 180
  vncPort: 5900
vmImage:
  alwaysRedownload: false
  refreshHours: 168
vmStart:
  bootDelaySeconds: 15
  cachingProxyIP: ''
  startTimeoutSeconds: 120
  testVmNamePrefix: test-
