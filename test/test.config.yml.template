configService:
  isEnabled: true
  port: 8443
guestSequence:
- guest.amazon.linux.2023
- guest.ubuntu.server.24
- guest.ubuntu.server.26
logLevel: Information
networkStorage:
  poolLocalPath: ""
  poolNetworkPath: ""
  poolNetworkUser: ""
  stashLocalPath: ""
  stashNetworkPath: ""
  stashNetworkUser: ""
notification:
  failuresBeforeAlert: 2
  successesBeforeRearm: 5
pool:
  enabled: false
  intentGitUrl: ""
  localClonePath: ""
  networkReplicate: false
  pullTimeoutSeconds: 30
repositories:
  frameworkUrl: https://github.com/alissonsol/yuruna
  GH_TOKEN: ""
  projectUrl: https://github.com/alissonsol/yuruna-project
statusService:
  isEnabled: true
  port: 8080
testCycle:
  autoRemediationEnabled: false
  autoRemediationMaxAttemptsPerCycle: 2
  cycleDelaySeconds: 300
  # Circuit breaker: skip a guest that keeps failing the same way, so it stops
  # burning a full provision+deploy every cycle. After failuresToQuarantine
  # consecutive failures of the SAME failureClass, the guest is skipped for up
  # to skipCycles cycles or until a framework/project commit changes (whichever
  # comes first), emitting a guest_quarantined event + a dashboard flag. Set
  # enabled:false to disable.
  guestQuarantine:
    enabled: true
    failuresToQuarantine: 3
    skipCycles: 5
  recentDisplayCount: 30
  shouldStopOnFailure: false
  stepTimeoutMinutes: 45
  # Warm-resume checkpointing: on an eligible transient workload failure
  # (network_timeout / wait_timeout / instrumentation_failure / host_io_blocked),
  # re-run the failed sequence from its last-good step on the same live VM
  # instead of tearing the guest down and redoing the whole install. Up to
  # maxAttempts in-place tries; on exhaustion it falls back to the normal
  # teardown + cold re-provision. Emits a warm_resume event. enabled:false
  # disables it.
  warmResume:
    enabled: true
    maxAttempts: 2
vmCommunication:
  allowGuiFallback: false
  characterDelayMs: 10
  keystrokeMechanism: GUI
  pollSeconds: 5
  timeoutSeconds: 180
  vncPort: 5900
vmImage:
  alwaysRedownload: false
  refreshHours: 168
vmStart:
  bootDelaySeconds: 15
  cachingProxyIP: ""
  startTimeoutSeconds: 120
  testVmNamePrefix: test-
