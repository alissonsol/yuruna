#cloud-config
autoinstall:
  version: 1
  # When a squid-cache VM is reachable, New-VM.ps1 expands the
  # placeholder line below into:
  #   apt:
  #     geoip: false
  #     primary: [{arches: [default], uri: http://ports.ubuntu.com/ubuntu-ports}]
  #     proxy: http://<squid>:3128
  # The literal token must NOT appear anywhere else in this file — New-VM.ps1
  # uses String.Replace(), which is a substring match, not token-aware, and
  # a stray mention inside a comment would splice the multi-line YAML into
  # the comment text and produce invalid YAML (subiquity then silently falls
  # back to the full interactive installer — language/keyboard/mirror prompts).
  # Rationale for the full block (vs. just `proxy:`):
  #   * proxy   — route apt through squid. (Subiquity also exports this as
  #               http_proxy/https_proxy globally; see proxy.py:43-44.)
  #   * primary — pin the arm64 mirror. Apple Silicon UTM is arm64, so
  #               ports.ubuntu.com is the correct repo. Without this,
  #               subiquity geoip-elects archive.ubuntu.com (amd64) which
  #               404s through the proxy and drives mirror.py's retry loop.
  #   * geoip   — false. The HTTPS geoip.ubuntu.com lookup otherwise goes
  #               through squid and can stall on CONNECT, keeping the
  #               retry loop alive.
  # The retry loop is what causes the console spam
  #   "start/finish: subiquity/Network/_send_update: CHANGE enp0s1"
  # — each mirror retry's netplan re-apply fires RTM_NEWLINK events that
  # subiquity's update_link → _send_update consumes. Pinning primary +
  # disabling geoip makes election succeed on the first try and the loop
  # exits. Without a reachable cache the whole block stays empty and
  # subiquity fetches direct from Ubuntu mirrors.
  #
  # Why the Server ISO instead of the Desktop ISO: only the Server ISO ships
  # linux-generic on the cdrom, so curtin's install_kernel step always succeeds
  # without network. The Desktop 24.04 arm64 ISO does not, and curtin's
  # install_kernel fails with "Unable to locate package linux-generic[-hwe-24.04]"
  # because the target chroot only has cdrom sources by then.
  #
  # Caveat: BOTH the Server and Desktop ISOs' base squashfs ship
  # /etc/apt/sources.list.d/ubuntu.sources with a cdrom-only entry, and
  # subiquity's apt-config stage only writes the legacy
  # /etc/apt/sources.list — it does NOT rewrite the deb822 ubuntu.sources
  # even with apt.preserve_sources_list=false + primary + sources_list.
  # On noble, apt treats ubuntu.sources as authoritative, so the chroot
  # never reaches ports.ubuntu.com and subiquity's postinstall
  # `apt install ubuntu-desktop` fails with "Unable to locate package"
  # (ubuntu-desktop is NOT on the Server cdrom). The early-commands
  # block below rewrites ubuntu.sources to ports.ubuntu.com before
  # postinstall runs — same hook is mirrored in the Desktop user-data
  # for consistency.
  #
  # We bolt ubuntu-desktop on top via the autoinstall.packages list below —
  # with the sources fix in place, subiquity fetches it through the
  # squid-cache during install, so the first boot lands straight in GDM.
APT_PROXY_BLOCK_PLACEHOLDER
  locale: en_US.UTF-8
  keyboard:
    layout: us
  packages:
    # Desktop environment. Installed by subiquity during the install step,
    # via apt against ubuntu-ports — through squid-cache when available.
    # ~2 GB of .deb payload; caching makes guest rebuilds dramatically
    # faster and dodges 429s on repeated pulls of libreoffice / gnome-shell.
    - ubuntu-desktop
    - console-setup
    - keyboard-configuration
  identity:
    hostname: HOSTNAME_PLACEHOLDER
    username: ubuntu
    password: "HASH_PLACEHOLDER"
  storage:
    layout:
      name: lvm
  ssh:
    # The Server cdrom DOES ship openssh-server, so install-server: true
    # works here (unlike the Desktop ISO variant, where openssh-server has
    # to be deferred to first-boot cloud-init).
    install-server: true
    allow-pw: true
    authorized-keys:
      - SSH_AUTHORIZED_KEY_PLACEHOLDER
  # Server autoinstall typically presents a confirmation prompt in the
  # text installer. interactive-sections: [] disables every interactive
  # step, so the install runs fully unattended — no "Install" button
  # click or Tab-to-focus dance like the Desktop ISO required.
  interactive-sections: []
  # Fix /etc/apt/sources.list.d/ubuntu.sources in the target. On noble 24.04.4
  # BOTH Server and Desktop ISO base squashfs ship this file cdrom-only, and
  # curtin's apt-config stage does not update the deb822 file (it only touches
  # the legacy /etc/apt/sources.list). On noble, apt treats ubuntu.sources as
  # authoritative, so the chroot never sees ports.ubuntu.com and the postinstall
  # `apt install ubuntu-desktop` fails with "Unable to locate package" (not on
  # the Server cdrom). See the full diagnosis in the block comment above the
  # APT_PROXY_BLOCK_PLACEHOLDER line.
  #
  # /target doesn't exist at early-commands time (storage + extract happen
  # later), so this backgrounds a watcher that waits for ubuntu.sources to
  # appear and overwrites it with ports.ubuntu.com URIs. ~120s covers
  # extract → curthooks → postinstall on both Apple VZ (UTM) and Hyper-V.
  # The watcher is idempotent (grep guard skips rewriting once the fix is
  # in place) so repeated polls don't thrash the file. Kept mirrored in
  # guest.ubuntu.desktop/vmconfig/user-data for consistency — Desktop's
  # install-time packages list is cdrom-only today, but the hook future-
  # proofs any pkg added there, and makes the installed system's
  # ubuntu.sources actually usable for first-boot apt work regardless of
  # variant.
  early-commands:
    - |
      nohup bash <<'WATCHER' > /var/log/yuruna-fix-ubuntu-sources.log 2>&1 &
      TARGET_FILE=/target/etc/apt/sources.list.d/ubuntu.sources
      for i in $(seq 1 120); do
        if [ -f "$TARGET_FILE" ] && ! grep -q ports.ubuntu.com "$TARGET_FILE"; then
          cat > "$TARGET_FILE" << 'SOURCES'
      Types: deb
      URIs: http://ports.ubuntu.com/ubuntu-ports/
      Suites: noble noble-updates noble-backports
      Components: main restricted universe multiverse
      Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg

      Types: deb
      URIs: http://ports.ubuntu.com/ubuntu-ports/
      Suites: noble-security
      Components: main restricted universe multiverse
      Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg
      SOURCES
          echo "$(date -u +%FT%TZ) rewrote $TARGET_FILE"
        fi
        sleep 1
      done
      WATCHER
  late-commands:
    # --- Apt cache: persist proxy into the installed system ---
    # Belt-and-suspenders with autoinstall.apt.proxy: subiquity already
    # writes an apt proxy config into the target when apt.proxy is set,
    # but we explicitly write 99yuruna-apt-cache so (a) the file name is
    # predictable for debugging, and (b) behavior is unchanged if
    # subiquity's apt-persistence logic ever drifts.
    - |
      if [ -n "CACHING_PROXY_URL_PLACEHOLDER" ]; then
        echo 'Acquire::http::Proxy "CACHING_PROXY_URL_PLACEHOLDER";' > /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        chmod 0644 /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        # --- HTTPS caching opt-in ---
        # guest.ubuntu.server/New-VM.ps1 runs on the host and fetches the
        # squid-cache CA directly (VZ shared-NAT blocks guest↔guest for
        # the CA-fetch scenario where the cache is a co-tenant VM). When
        # the fetch succeeds the CA bytes arrive here base64-encoded;
        # this block decodes them into the target, updates the trust
        # store, and points Acquire::https::Proxy at the :3129 ssl-bump
        # listener on the same host as the HTTP proxy — the guest reaches
        # it over the standard shared-NAT route the HTTP side already
        # uses. (Earlier revisions indirected through a host-side port
        # forwarder at 192.168.64.1:3129; that forwarder never existed
        # on this setup, so every HTTPS apt call died with "Connection
        # refused," silently aborting the Docker install.) Empty
        # placeholder → no-op, HTTPS apt bypasses.
        if [ -n "CA_CERT_BASE64_PLACEHOLDER" ]; then
          mkdir -p /target/usr/local/share/ca-certificates
          printf '%s' "CA_CERT_BASE64_PLACEHOLDER" | base64 -d > /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
          chmod 0644 /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
          curtin in-target --target=/target -- update-ca-certificates
          CACHE_HOST=$(echo "CACHING_PROXY_URL_PLACEHOLDER" | sed -E 's|^https?://([^:/]+).*|\1|')
          echo "Acquire::https::Proxy \"http://${CACHE_HOST}:3129\";" >> /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        fi
      fi
    # --- Cap systemd-networkd-wait-online so first boot doesn't hang ---
    # Ubuntu 24.04's networkd-wait-online defaults to "wait for ALL
    # configured interfaces to reach 'routable' with no timeout." On
    # Apple Virtualization's shared NAT the IPv6 Router Advertisements
    # this tracker expects never arrive, and the service blocks forever —
    # visible on the serial console as:
    #   Job systemd-networkd-wait-online.service/start running ([TIME] / no limit)
    # Cloud-init's first-boot run depends (transitively) on
    # network-online.target, so a stuck wait-online cascades into a
    # cloud-init failure on UTM. On Hyper-V Default Switch the IPv6
    # eventually resolves so the wait completes, just slowly — same
    # override helps there too. --any --timeout=30 means "ANY one
    # interface is routable OR 30s elapsed, whichever first."
    - mkdir -p /target/etc/systemd/system/systemd-networkd-wait-online.service.d
    - |
      cat > /target/etc/systemd/system/systemd-networkd-wait-online.service.d/override.conf << 'EOF'
      [Service]
      ExecStart=
      ExecStart=/lib/systemd/systemd-networkd-wait-online --any --timeout=15
      EOF
    # --- Security: user account ---
    - curtin in-target --target=/target -- passwd --expire ubuntu
    # --- Sudo: grant the ubuntu user passwordless sudo for the test harness ---
    - curtin in-target --target=/target -- bash -c 'echo "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/90-yuruna-ubuntu && chmod 440 /etc/sudoers.d/90-yuruna-ubuntu && chown root:root /etc/sudoers.d/90-yuruna-ubuntu'
    # --- System: disable swap ---
    - sed -i '/ swap / s/^/#/' /target/etc/fstab
    - curtin in-target --target=/target -- systemctl mask swap.target
    # --- System: disable MOTD ---
    - chmod -x /target/etc/update-motd.d/*
    - mkdir -p /target/etc/default && test -f /target/etc/default/motd-news && sed -i 's/^ENABLED=1/ENABLED=0/' /target/etc/default/motd-news || echo 'ENABLED=0' > /target/etc/default/motd-news
    # --- GNOME: skip initial setup ---
    # /etc/skel marker is copied into new user home dirs; /home/ubuntu gets
    # its own copy in case the autoinstall user was already created before
    # /etc/skel was populated.
    - curtin in-target --target=/target -- mkdir -p /etc/skel/.config
    - echo 'yes' > /target/etc/skel/.config/gnome-initial-setup-done
    - curtin in-target --target=/target -- mkdir -p /home/ubuntu/.config
    - echo 'yes' > /target/home/ubuntu/.config/gnome-initial-setup-done
    - curtin in-target --target=/target -- chown -R ubuntu:ubuntu /home/ubuntu/.config
    # --- GNOME: auto-open terminal on login ---
    - curtin in-target --target=/target -- mkdir -p /etc/xdg/autostart
    - |
      cat > /target/etc/xdg/autostart/open-terminal.desktop << 'DESKTOP'
      [Desktop Entry]
      Type=Application
      Name=Open Terminal
      Exec=gnome-terminal
      X-GNOME-Autostart-enabled=true
      NoDisplay=true
      DESKTOP
    # --- IBus: stub out ibus-daemon to avoid the gdm greeter input-method race ---
    # On Ubuntu 24.04 + GNOME 46, the gdm greeter's gnome-shell spawns two
    # ibus-daemon instances back-to-back and the second replaces the first,
    # orphaning gnome-shell's InputContext D-Bus proxy. Key presses to the
    # greeter text entry are then silently swallowed. dpkg-divert +
    # ln -s /bin/true makes gnome-shell's ibus-daemon exec return immediately,
    # bypassing the race. ubuntu-desktop is in autoinstall.packages so
    # /usr/bin/ibus-daemon exists by the time late-commands run.
    - curtin in-target --target=/target -- dpkg-divert --local --add --rename /usr/bin/ibus-daemon
    - curtin in-target --target=/target -- ln -sf /bin/true /usr/bin/ibus-daemon
    # --- GNOME: enable automatic timezone (requires dconf, installed with ubuntu-desktop) ---
    - mkdir -p /target/etc/dconf/db/local.d
    - |
      cat > /target/etc/dconf/db/local.d/00-timezone << 'DCONF'
      [org/gnome/desktop/datetime]
      automatic-timezone=true

      [org/gnome/system/location]
      enabled=true
      DCONF
    # --- GDM greeter: never blank the display ---
    # ubuntu.desktop.update.sh disables idle/lock for the ubuntu USER, but
    # that profile does NOT apply to the GDM greeter — which runs under the
    # `gdm` system-db profile. With the default idle-delay, the greeter
    # blanks after ~3 min, hypervisor screen captures return pure black, OCR
    # extracts no text, and Test-Workload step 1 ("Not listed?") times out
    # even though the greeter would render correctly if anyone touched the
    # VM. A dconf drop-in in /etc/dconf/db/gdm.d/ + dconf update is the
    # Canonical-documented way to override greeter settings at install time.
    - mkdir -p /target/etc/dconf/db/gdm.d
    - |
      cat > /target/etc/dconf/db/gdm.d/99-yuruna-no-idle << 'DCONF'
      [org/gnome/desktop/session]
      idle-delay=uint32 0

      [org/gnome/settings-daemon/plugins/power]
      sleep-inactive-ac-type='nothing'
      sleep-inactive-battery-type='nothing'
      idle-dim=false
      power-button-action='nothing'

      [org/gnome/desktop/screensaver]
      lock-enabled=false
      idle-activation-enabled=false
      DCONF
    - curtin in-target --target=/target -- dconf update
    # --- Network: download fetch-and-execute utility ---
    - mkdir -p /target/automation
    - wget --no-cache -O /target/automation/fetch-and-execute.sh "https://raw.githubusercontent.com/alissonsol/yuruna/refs/heads/main/automation/fetch-and-execute.sh"
    - curtin in-target --target=/target -- chmod +x /automation/fetch-and-execute.sh
    # --- Network: timezone detection via IP geolocation and NTP ---
    - curtin in-target --target=/target -- timedatectl set-ntp true
    - curtin in-target --target=/target -- bash -c 'command -v wget >/dev/null 2>&1 && TZ=$(wget -qO - --timeout=5 "http://ip-api.com/line?fields=timezone") && [ -n "$TZ" ] && timedatectl set-timezone "$TZ" || echo "Yuruna => Timezone sync failed (check wget, network, or API)" >&2'
