#cloud-config
hostname: apt-cache
package_update: true
packages:
  - apt-cacher-ng
  # hyperv-daemons provides hv_kvp_daemon so the host's
  # Get-VMNetworkAdapter cmdlet can read the guest's IP address.
  # Without it, the host reports an empty IPAddresses list forever.
  - hyperv-daemons
runcmd:
  # apt-cacher-ng starts automatically after install; ensure it survives reboot
  - systemctl enable apt-cacher-ng
  - systemctl start apt-cacher-ng
  # Start the Hyper-V KVP daemon so the host can discover our IP.
  - systemctl enable hv-kvp-daemon.service
  - systemctl start hv-kvp-daemon.service
  # Signal readiness on the console (the test harness can poll port 3142 instead)
  - echo "apt-cacher-ng ready on port 3142"
