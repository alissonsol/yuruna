package_update: true
packages:
  # squid-openssl: OpenSSL-linked build of squid. On Ubuntu Noble the
  # default `squid` is built WITHOUT --with-openssl (Debian licensing
  # split), so its http_port parser rejects ssl-bump / tls-cert= with a
  # "Bungled" FATAL at config-load and squid.service never binds a
  # socket. squid-openssl installs the same /usr/sbin/squid and same
  # squid.service unit, and `Conflicts: squid` makes it idempotent.
  - squid-openssl
  # squid-cgi: cachemgr.cgi (CGI front-end to Squid's cache manager).
  # apache2 hosts it via conf.d/serve-cgi-bin.conf once we a2enmod cgi
  # in runcmd. Low-overhead fallback when the Grafana UI is down.
  - squid-cgi
  # squidclient (/usr/bin/squidclient) — cache-manager queries + PURGE.
  # Ships in squid-common, which squid-openssl already pulls in, so no
  # additional package needed. The previous entry `- squid-cli` was based
  # on a wrong assumption (no such package on noble): cloud-init's
  # dpkg-verify post-install check raised, marking the packages module
  # as failed and leaving `cloud-init status` in `error` for the lifetime
  # of the instance. From any RFC1918 host:
  #   curl -x http://<cache>:3128 -X PURGE http://<origin>:<port>/<path>
  - apache2
  # Monitoring stack. Prometheus scrapes squid-exporter (localhost:9301)
  # and Grafana renders on :3000 (anonymous Viewer). squid-exporter has
  # no apt package and no stable GitHub release URL, so golang-go is
  # pulled in just long enough to `go install` it; both build tools are
  # purged at the end of runcmd to reclaim ~400 MB (the /usr/local/bin/
  # squid-exporter binary stays). Grafana's arm64 build is in the same
  # apt.grafana.com repo, so Hyper-V (amd64) and UTM (arm64) both resolve.
  #
  # loki + promtail back the "Recent 100 requests" Grafana panel — Prometheus
  # only stores aggregates, so per-request client IP / target URL are not
  # available there. Promtail tails /var/log/squid/access.log and ships to
  # Loki on localhost:3100. Both come from apt.grafana.com (same repo as
  # grafana) and ship arm64 builds, so this works on UTM too.
  - prometheus
  - grafana
  - loki
  - promtail
  - golang-go
  # Interactive triage tools for the cache VM console/SSH. Noble's
  # server cloud image ships `ip` (iproute2) but NOT `ifconfig` or
  # `ping`, so muscle-memory commands fail without these.
  - net-tools       # ifconfig, netstat, route, arp
  - iputils-ping    # ping, ping6
  # openssl CLI for the one-shot CA-generation step in runcmd. The cloud
  # image ships libssl but not /usr/bin/openssl, so `req -x509` would
  # fail with "command not found" and squid's :3129 couldn't load
  # tls-cert/tls-key. Kept as a top-level package (not apt-get in runcmd)
  # so failure surfaces in the normal install phase.
  - openssl
write_files:
  # Retry apt fetches on transient network errors. Cloud-init's default
  # is one-shot; a single timeout or TCP reset fails the whole package
  # install and leaves the VM without squid (the "Exit code: 100 /
  # Stdout: -" failure against `apt-get install apache2 squid`).
  # Retries=5 covers hiccups; apt still treats 4xx (429/404) as fatal
  # -- those need operator attention in /var/log/cloud-init-output.log.
  - path: /etc/apt/apt.conf.d/80-yuruna-retries
    permissions: '0644'
    owner: root:root
    content: |
      Acquire::Retries "5";
      Acquire::Retries::Delay-Max "60";
  # Restrict cachemgr.cgi to RFC1918 sources, matching the squid ACL.
  # Apache's default cgi-bin/ serve is open to all -- UTM Shared NAT in
  # practice blocks outside reach, but aligning Apache with squid means
  # a misconfigured network can't accidentally expose the cache manager.
  # (Historical note: the 99yuruna-prewarm-proxy apt dropin used to
  # live in write_files. That was a bootstrap bug -- write_files runs
  # BEFORE `packages:`, so apt tried to fetch squid itself through
  # 127.0.0.1:3128 before squid existed, failed with Exit code 100, and
  # squid never got installed. The dropin is now written LATER in
  # runcmd, only after squid is confirmed listening.)
  - path: /etc/apache2/conf-available/yuruna-cachemgr.conf
    permissions: '0644'
    owner: root:root
    content: |
      <Location /cgi-bin/cachemgr.cgi>
          Require ip 127.0.0.1
          Require ip 10.0.0.0/8
          Require ip 172.16.0.0/12
          Require ip 192.168.0.0/16
      </Location>
  # Drop-in overrides on top of Ubuntu's stock /etc/squid/squid.conf.
  # conf.d files are included after the main config, so same-named
  # directives here win. Drop-in (not full replacement) means future
  # squid upgrades still get their default refresh_pattern + ACL baseline.
  - path: /etc/squid/conf.d/yuruna.conf
    permissions: '0644'
    owner: root:root
    content: |
      # yuruna squid-cache -- generic HTTP proxy/cache for test-VM
      # installs. Replaces apt-cacher-ng, which only cached .deb URLs
      # and still let security.ubuntu.com 429s bubble to subiquity's
      # direct pre-install kernel fetch. Squid caches any cacheable HTTP
      # response, so subsequent installs no longer race the rate limiter.
      # On macOS all UTM VMs egress through the host's single public IP
      # via Apple Virtualization Shared NAT -- the per-source rate limit
      # bites faster than on Hyper-V.

      # NOTE: we do NOT set `http_port 3128` here. Ubuntu's stock
      # /etc/squid/squid.conf already declares it, and /etc/squid/conf.d/*
      # is INCLUDED (not overlaid) into the main config. Declaring
      # `http_port 3128` twice makes the second bind fail with EADDRINUSE
      # ("listen (..., 256) system call failed: (98) Address already in
      # use") while squid still appears 'running'. The default binding
      # (all interfaces, 3128) is what we want.

      # Permit only RFC1918 sources. UTM Shared mode hands out
      # 192.168.64.0/24; 10/8 and 172.16/12 entries cover alternate
      # network modes so this config stays reusable.
      acl yuruna_local src 10.0.0.0/8
      acl yuruna_local src 172.16.0.0/12
      acl yuruna_local src 192.168.0.0/16

      # --- Cache purge (PURGE method for local operators) ---
      # squidclient -m PURGE invalidates a single cached entry without
      # reloading. Usage:
      #   From the cache VM:
      #     sudo squidclient -m PURGE http://<origin>:<port>/<path>
      #   From any RFC1918 host:
      #     curl -x http://<cache>:3128 -X PURGE http://<origin>:<port>/<path>
      # MUST appear before the generic `http_access allow yuruna_local`:
      # http_access is first-match-wins top-down, so the generic allow
      # would otherwise match PURGE from yuruna_local before the method-
      # scoped rule, making the explicit deny dead code. Tightening
      # later (e.g. swapping yuruna_local for localhost) would then
      # silently do nothing. Keep the PURGE block above the generic allow.
      acl yuruna_purge method PURGE
      http_access allow yuruna_purge yuruna_local
      http_access deny yuruna_purge

      http_access allow yuruna_local

      # --- Snapshot-cache tuning ---
      # Tuned as a replayable snapshot:
      #   1. objects stay until disk is nearly full (no proactive release)
      #   2. keeps serving when origin is unreachable or sends
      #      cache-hostile headers
      #   3. with offline_mode (flipped on in runcmd after prewarm), a
      #      fully-populated cache supports guest installs offline.
      #
      # cache_replacement_policy MUST precede cache_dir -- squid binds
      # the policy at cache_dir-parse time, so a later override no-ops.
      # heap LFUDA (disk) and heap GDSF (memory) prefer frequently-used
      # large objects (linux-firmware, kernels) and drop rarely-touched
      # small ones first when eviction fires -- big, expensive-to-refetch
      # blobs survive, which is what offline replay needs.
      cache_replacement_policy heap LFUDA
      memory_replacement_policy heap GDSF

      # Disk cache for a 144 GB virtual disk: 128 GB squid + ~16 GB OS
      # headroom. ufs is simplest; switch to aufs/diskd only if squid
      # blocks on disk I/O under concurrent installs.
      cache_dir ufs /var/spool/squid 131072 16 256
      # 16 GB ceiling so the snapshot cache covers any modern OS install
      # image we might pre-warm: Windows 11 ISO (~6 GB), Ubuntu desktop
      # (~5 GB and trending up), Fedora Workstation Live (~3 GB), and
      # CI-time ISOs that bundle drivers/firmware. Squid's
      # maximum_object_size is INCLUSIVE -- anything strictly larger is
      # silently NOT cached, so a 4 GB ceiling failed open the moment
      # noble-desktop crossed 4 GB. 16 GB leaves headroom; raising it
      # doesn't allocate disk, only changes the rejection threshold.
      maximum_object_size 16 GB
      maximum_object_size_in_memory 32 MB
      cache_mem 512 MB

      # Only start evicting when disk is >99% full, stopping at 98%.
      # Default 90/95 would release objects with ~5 GB free remaining --
      # wrong for a sticky snapshot cache.
      cache_swap_high 99
      cache_swap_low  98

      # Don't cache failures (404, 5xx). A transient blip must not
      # become a poisoned 504 returned forever for an object squid
      # could otherwise fetch successfully next time.
      negative_ttl 0 seconds

      # Never abort partial downloads. If a client disconnects mid-fetch
      # (e.g. guest reboot), squid finishes the fetch so the next client
      # gets a cache hit. -1 KB disables the quick-abort threshold.
      quick_abort_min -1 KB

      # Pool concurrent identical fetches: when N machines start the
      # same uncached ISO at once, squid forwards ONE request to origin
      # and the other N-1 ride along the in-progress fetch. Without
      # this, every client races to origin in parallel -- both wasting
      # mirror bandwidth and tripping per-IP rate limits at
      # releases.ubuntu.com when a CI swarm rebuilds. Has no effect on
      # CONNECT-tunneled HTTPS (uncacheable by definition); applies to
      # HTTP origins and to SSL-bumped HTTPS on :3129.
      collapsed_forwarding on

      # Range-request handling for big-object caching. Default (`0`)
      # means: when a client sends `Range: bytes=...`, squid forwards
      # the partial to origin and serves it back WITHOUT populating the
      # cache -- so range/resumed downloads (BITS, browser resume, curl
      # --range, apt's pdiff fetcher) leave nothing behind for the next
      # client. `none` (= unbounded) tells squid to fetch the FULL
      # object on first range request and serve subsequent ranges from
      # cache. Critical for the "many machines hit the same large ISO"
      # scenario, where the first hit may well be a resume.
      range_offset_limit none

      # Package files are content-addressable (version in the URL), so
      # a new version is a different URL -- no value in revalidation.
      # override/ignore flags keep squid serving these regardless of
      # origin or intermediate cache-control hints. 525600 min = 1 year.
      refresh_pattern -i \.deb$      525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.udeb$     525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.tar\.xz$  525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.tar\.gz$  525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.tar\.bz2$ 525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.iso$      525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      # Apt metadata (InRelease, Packages.*) moves — poll origin each time.
      refresh_pattern -i /InRelease$                    0 0%  60
      refresh_pattern -i /Release$                      0 0%  60
      refresh_pattern -i /Release\.gpg$                 0 0%  60
      refresh_pattern -i /Packages(\.gz|\.xz|\.bz2)?$   0 0%  60
      refresh_pattern -i /Sources(\.gz|\.xz|\.bz2)?$    0 0%  60

      logfile_rotate 2

      # --- HTTPS caching via SSL-bump (second listener on :3129) ---
      # Stock :3128 stays a pure CONNECT-tunnel for HTTPS (no MITM, no
      # caching, no cert trust required). That keeps legacy clients and
      # subiquity's pre-install HTTPS calls (which run before our CA
      # reaches the target chroot) working as before.
      #
      # :3129 is the opt-in ssl-bump listener. Guests whose trust store
      # contains /etc/squid/ssl_cert/ca.pem (published at
      # http://<cache>/yuruna-squid-ca.crt by Apache below) can point
      # Acquire::https::Proxy there and get HTTPS apt traffic
      # intercepted, cached, and replayed through the same
      # refresh_pattern + offline_mode pipeline.
      #
      # peek-step1-then-bump-all is the minimum-viable recipe: squid
      # reads the TLS ClientHello for SNI, generates a per-host leaf
      # cert signed by the yuruna CA, and terminates the client side.
      # For a pin-checking client (snap, Go binaries), add
      # `acl nobump dstdomain ...` + `ssl_bump splice nobump` ABOVE
      # the bump-all line rather than disabling bumping wholesale.
      #
      # `acl step1` MUST be declared explicitly; squid does not
      # auto-define at_step ACLs. Without this line, `ssl_bump peek
      # step1` FATALs "Bungled ... ssl_bump peek step1" at config-load
      # and squid never binds 3128/3129.
      acl step1 at_step SslBump1
      #
      # NOTE: dynamic_cert_mem_cache_size is a TOP-LEVEL directive in
      # Squid 6 (Ubuntu Noble), NOT an http_port option. An earlier
      # revision inlined it on the http_port line and tripped a parser
      # "Bungled" error that kept squid from starting. 4 MB is the
      # default anyway; we leave the default stand.
      http_port 3129 ssl-bump generate-host-certificates=on tls-cert=/etc/squid/ssl_cert/ca.pem tls-key=/etc/squid/ssl_cert/ca.key
      sslcrtd_program /usr/lib/squid/security_file_certgen -s /var/lib/squid/ssl_db -M 4MB
      sslcrtd_children 5
      ssl_bump peek step1
      ssl_bump bump all

      # --- PROXY-protocol-aware listeners for the host-side userspace
      # forwarder. Without these, every connection that came through
      # the host pwsh forwarder appeared in access.log as the host's
      # NAT-side IP because TCP forwarding rewrites the source. The
      # forwarder (Test.PortMap on Windows / VM.common.psm1 on macOS)
      # prepends a HAProxy PROXY v1 header; squid parses it on these
      # ports and uses the supplied client IP for ACLs and access.log.
      #
      # NOTE: option name is `require-proxy-header` in Squid 6 (Noble),
      # NOT `accept-proxy-protocol` (the squid 4 / older-docs name).
      # Using the old name FATALs at parse:
      #   "Unknown http_port option 'accept-proxy-protocol'"
      # Same semantics either way — every connection on the port MUST
      # start with a PROXY v1 (or v2) header.
      #
      # Separate ports (not the same 3128/3129) because require-proxy-header
      # mandates a PROXY header — local Shared-NAT guests that connect
      # directly without one still hit 3128/3129.
      #
      # proxy_protocol_access controls which client IPs may send PROXY
      # headers (i.e. which proxies are trusted to vouch for client IPs).
      # Allow RFC1918 + loopback — the host forwarder lives on a private
      # network (UTM Shared NAT 192.168.64.0/24); loopback covers on-VM
      # diagnostics like `python3 -c 'socket... PROXY TCP4 ...'` against
      # 127.0.0.1:3138 to spot-check the path without a real LAN client.
      acl yuruna_proxy_senders src 10.0.0.0/8
      acl yuruna_proxy_senders src 172.16.0.0/12
      acl yuruna_proxy_senders src 192.168.0.0/16
      acl yuruna_proxy_senders src 127.0.0.1/32
      acl yuruna_proxy_senders src ::1/128
      proxy_protocol_access allow yuruna_proxy_senders
      proxy_protocol_access deny all
      http_port 3138 require-proxy-header
      http_port 3139 require-proxy-header ssl-bump generate-host-certificates=on tls-cert=/etc/squid/ssl_cert/ca.pem tls-key=/etc/squid/ssl_cert/ca.key

      # --- Custom access-log format for the Grafana "Recent 100 requests"
      # panel. %>a (client IP) + status + size + method + URL, with the
      # request User-Agent appended in literal double-quotes so the panel
      # can distinguish apt / curl / snap / Docker / Go traffic — far
      # more diagnostic for this single-host workload than reverse-DNS
      # hostnames.
      #
      # An earlier revision also captured %>A (client FQDN). On Squid 6
      # %>A triggers a synchronous PTR lookup, and on RFC1918 source IPs
      # the resolver routinely returns whatever unrelated registered host
      # owns the IP upstream — making the "client_host" column actively
      # misleading on a single-host test harness where most traffic is
      # local infra (the squid VM itself on 127.0.0.1, the host gateway,
      # sibling guest VMs). %>A is gone for that reason; friendly names
      # for the host gateway live in /etc/hosts (runcmd below) for
      # operators tailing the log directly.
      #
      # User-Agent in literal double-quotes: %{...}>h doesn't auto-escape
      # spaces, and apt/curl/wget/snap/Docker UAs contain spaces but no
      # quotes — quoting cleanly delimits the field. Missing header logs
      # as `"-"`; the regex tolerates it.
      #
      # Output goes to a SEPARATE file (yuruna_access.log) — the default
      # access.log keeps its stock `squid` format for cachemgr.cgi and
      # manual `tail -f /var/log/squid/access.log` debugging. Two squid
      # access_log entries writing the same file would interleave bytes
      # and corrupt both formats.
      logformat yuruna %ts.%03tu %6tr %>a %Ss/%03>Hs %<st %rm %ru %[un %Sh/%<a %mt "%{User-Agent}>h"
      access_log /var/log/squid/yuruna_access.log yuruna
  # --- Prometheus on loopback only; Grafana (same VM) scrapes via
  # localhost. Keeps Prometheus's open-access UI off the host LAN;
  # :3000 Grafana is the only exposed entry point.
  - path: /etc/default/prometheus
    permissions: '0644'
    owner: root:root
    content: |
      ARGS="--web.listen-address=127.0.0.1:9090"
  - path: /etc/prometheus/prometheus.yml
    permissions: '0644'
    owner: root:root
    content: |
      global:
        scrape_interval: 15s
      scrape_configs:
        - job_name: prometheus
          static_configs:
            - targets: ['localhost:9090']
        - job_name: squid
          static_configs:
            - targets: ['localhost:9301']
  # --- Loki: log datastore for the access-log panel. Loopback-only;
  # Grafana scrapes via localhost. Single-binary monolithic config with
  # filesystem TSDB — no object store, no extra services. Retention capped
  # at 7d (compactor enabled) so /var/lib/loki doesn't grow unbounded for
  # what's effectively a "last 100 requests" UX.
  #
  # Pre-written via write_files; the loki deb's postinst respects
  # cloud-init's --force-confold and keeps this file. Without explicit
  # http_listen_address the deb default is 0.0.0.0 — same exposure issue
  # as Prometheus, fixed the same way.
  - path: /etc/loki/config.yml
    permissions: '0644'
    owner: root:root
    content: |
      auth_enabled: false
      server:
        http_listen_address: 127.0.0.1
        http_listen_port: 3100
        grpc_listen_address: 127.0.0.1
        grpc_listen_port: 9096
      common:
        instance_addr: 127.0.0.1
        path_prefix: /var/lib/loki
        storage:
          filesystem:
            chunks_directory: /var/lib/loki/chunks
            rules_directory: /var/lib/loki/rules
        replication_factor: 1
        ring:
          kvstore:
            store: inmemory
      schema_config:
        configs:
          - from: 2024-01-01
            store: tsdb
            object_store: filesystem
            schema: v13
            index:
              prefix: index_
              period: 24h
      limits_config:
        retention_period: 168h
      compactor:
        working_directory: /var/lib/loki/compactor
        retention_enabled: true
        delete_request_store: filesystem
  # --- Promtail: tails /var/log/squid/access.log and ships each line to
  # Loki. Only the timestamp is parsed in promtail — keeps client IP and
  # URL out of Loki labels (high cardinality = stream explosion). The
  # Grafana panel re-parses with `regexp` at query time.
  #
  # positions.yaml on disk (not /tmp default) so reboots don't re-tail
  # the entire access.log. /var/lib/promtail is created in runcmd because
  # the deb postinst doesn't always.
  - path: /etc/promtail/config.yml
    permissions: '0644'
    owner: root:root
    content: |
      server:
        http_listen_address: 127.0.0.1
        http_listen_port: 9080
        grpc_listen_port: 0
      positions:
        filename: /var/lib/promtail/positions.yaml
      clients:
        - url: http://127.0.0.1:3100/loki/api/v1/push
      scrape_configs:
        - job_name: squid
          static_configs:
            - targets:
                - localhost
              labels:
                job: squid
                # yuruna_access.log is the custom logformat (defined in
                # /etc/squid/conf.d/yuruna.conf) — same fields as the
                # stock `squid` format plus a quoted "%{User-Agent}>h"
                # column at the end so the dashboard panel can split
                # apt / curl / snap / Docker / Go-http-client traffic.
                # The stock access.log keeps its default format for
                # cachemgr/tail debugging; only Promtail tails the
                # yuruna variant.
                __path__: /var/log/squid/yuruna_access.log
          pipeline_stages:
            - regex:
                expression: '^(?P<ts>\d+\.\d+)\s+\d+\s+'
            - timestamp:
                source: ts
                format: Unix
  # --- Promtail systemd drop-in: SupplementaryGroups=proxy so promtail
  # can read /var/log/squid/access.log (proxy:proxy 640) without
  # touching /etc/group via usermod. Declarative and survives package
  # upgrades. We can't put `Group=proxy` because the promtail deb on
  # Noble creates the user with primary group `nogroup` (its postinst
  # runs `adduser --system --group promtail` expecting an existing
  # `promtail` group; the group doesn't exist, adduser falls back to
  # nogroup, so there is no `promtail` group anywhere on the system —
  # don't reference one).
  - path: /etc/systemd/system/promtail.service.d/yuruna.conf
    permissions: '0644'
    owner: root:root
    content: |
      [Service]
      SupplementaryGroups=proxy
  # --- squid-exporter systemd unit. Binary is `go install`ed in runcmd;
  # unit starts after network + squid. Loopback-only (same-VM Prometheus
  # is the only consumer).
  - path: /etc/systemd/system/squid-exporter.service
    permissions: '0644'
    owner: root:root
    content: |
      [Unit]
      Description=Squid Prometheus exporter (boynux/squid-exporter)
      After=network-online.target squid.service
      Wants=network-online.target squid.service
      [Service]
      Type=simple
      User=nobody
      Group=nogroup
      ExecStart=/usr/local/bin/squid-exporter -listen 127.0.0.1:9301 -squid-hostname localhost -squid-port 3128
      Restart=on-failure
      RestartSec=5
      [Install]
      WantedBy=multi-user.target
  # --- Grafana: anonymous Viewer so operators hit the dashboard with no
  # login (no sign-up, no Grafana Cloud). Admin login (default admin/
  # admin) still works for editing dashboards. Standard systemd override
  # drop-in; Grafana reads GF_* env vars natively.
  - path: /etc/systemd/system/grafana-server.service.d/yuruna.conf
    permissions: '0644'
    owner: root:root
    content: |
      [Service]
      Environment=GF_AUTH_ANONYMOUS_ENABLED=true
      Environment=GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
  # --- Grafana datasources. UIDs pinned so the provisioned dashboard
  # below references each by stable name without knowing Grafana's auto-UID.
  - path: /etc/grafana/provisioning/datasources/yuruna.yaml
    permissions: '0644'
    owner: root:root
    content: |
      apiVersion: 1
      datasources:
        - name: Prometheus
          uid: yuruna-prometheus
          type: prometheus
          access: proxy
          url: http://localhost:9090
          isDefault: true
          editable: false
        - name: Loki
          uid: yuruna-loki
          type: loki
          access: proxy
          url: http://localhost:3100
          editable: false
  # --- Grafana dashboard provider: scans /var/lib/grafana/dashboards
  # for JSON. updateIntervalSeconds keeps them in sync if an operator
  # edits the on-disk file post-boot.
  - path: /etc/grafana/provisioning/dashboards/yuruna.yaml
    permissions: '0644'
    owner: root:root
    content: |
      apiVersion: 1
      providers:
        - name: yuruna
          folder: ''
          type: file
          disableDeletion: true
          updateIntervalSeconds: 30
          options:
            path: /var/lib/grafana/dashboards
  # --- Minimal squid dashboard. squid_client_* panels render once the
  # exporter is serving; if a metric name drifts between releases, the
  # affected panel shows "No data" but the rest still loads.
  - path: /var/lib/grafana/dashboards/squid.json
    permissions: '0644'
    owner: root:root
    content: |
      {
        "uid": "yuruna-squid",
        "title": "Yuruna Caching Proxy",
        "schemaVersion": 39,
        "version": 1,
        "refresh": "30s",
        "time": {"from": "now-2h", "to": "now"},
        "panels": [
          {
            "id": 2,
            "type": "timeseries",
            "title": "Client HTTP(S) requests/sec",
            "datasource": {"type": "prometheus", "uid": "yuruna-prometheus"},
            "gridPos": {"x": 0, "y": 0, "w": 24, "h": 6},
            "fieldConfig": {
              "defaults": {},
              "overrides": [
                {
                  "matcher": {"id": "byFrameRefID", "options": "A"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
                }
              ]
            },
            "targets": [{"expr": "rate(squid_client_http_requests_total[5m])", "refId": "A"}]
          },
          {
            "id": 3,
            "type": "timeseries",
            "title": "Client HTTP(S) hits/sec",
            "datasource": {"type": "prometheus", "uid": "yuruna-prometheus"},
            "gridPos": {"x": 0, "y": 6, "w": 24, "h": 6},
            "fieldConfig": {
              "defaults": {},
              "overrides": [
                {
                  "matcher": {"id": "byFrameRefID", "options": "A"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
                }
              ]
            },
            "targets": [{"expr": "rate(squid_client_http_hits_total[5m])", "refId": "A"}]
          },
          {
            "id": 6,
            "type": "timeseries",
            "title": "Client HTTP(S) data served (kB/s): total vs cached",
            "datasource": {"type": "prometheus", "uid": "yuruna-prometheus"},
            "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
            "fieldConfig": {
              "defaults": {},
              "overrides": [
                {
                  "matcher": {"id": "byName", "options": "Total"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
                },
                {
                  "matcher": {"id": "byName", "options": "Cached"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
                }
              ]
            },
            "targets": [
              {"expr": "rate(squid_client_http_kbytes_out_kbytes_total[5m])",     "refId": "A", "legendFormat": "Total"},
              {"expr": "rate(squid_client_http_hit_kbytes_out_bytes_total[5m])", "refId": "B", "legendFormat": "Cached"}
            ]
          },
          {
            "id": 7,
            "type": "logs",
            "title": "Recent 100 requests (client IP / status / size / method / URL / User-Agent)",
            "datasource": {"type": "loki", "uid": "yuruna-loki"},
            "gridPos": {"x": 0, "y": 20, "w": 24, "h": 12},
            "options": {
              "showTime": true,
              "showLabels": false,
              "showCommonLabels": false,
              "wrapLogMessage": false,
              "prettifyLogMessage": false,
              "enableLogDetails": true,
              "dedupStrategy": "none",
              "sortOrder": "Descending"
            },
            "targets": [
              {
                "expr": "{job=\"squid\"} | regexp `^\\S+\\s+\\S+\\s+(?P<client_ip>\\S+)\\s+(?P<status>\\S+)\\s+(?P<bytes>\\S+)\\s+(?P<method>\\S+)\\s+(?P<url>\\S+)\\s+\\S+\\s+\\S+\\s+\\S+\\s+\"(?P<ua>[^\"]*)\"` | line_format `{{.client_ip}}  {{.status}}  {{.bytes}}  {{.method}}  {{.url}}  {{.ua}}`",
                "refId": "A",
                "maxLines": 100
              }
            ]
          }
        ]
      }
runcmd:
  # /etc/hosts: friendly label for the default-route gateway. On UTM
  # Apple-VZ shared NAT that's 192.168.64.1 (the macOS host's interface
  # into the NAT), and it shows up as the client IP for every request a
  # host process proxies through this cache — most of the traffic on a
  # single-host test harness. Mapping it to `macos-host` lets operators
  # `host 192.168.64.1`, `ping macos-host`, and `awk '$3=="192.168.64.1"'
  # /var/log/squid/yuruna_access.log` resolve cleanly. Discovered from
  # `ip route show default` (not hardcoded) so a future networking change
  # — bridged mode, custom subnet — keeps this entry pointing at the
  # actual host. Idempotent: re-runs of cloud-init don't duplicate.
  - |
    GW=$(ip -4 route show default 2>/dev/null | awk '/default/ {print $3; exit}')
    if [ -n "$GW" ] && ! grep -q "^${GW}[[:space:]]" /etc/hosts; then
      echo "${GW} macos-host" >> /etc/hosts
    fi
  # Stop the squid that apt's postinst attempted to start — it is either
  # already FATAL (write_files dropped /etc/squid/conf.d/yuruna.conf with
  # `tls-cert=/etc/squid/ssl_cert/ca.pem` referenced before we generate
  # that cert below) or running with a partial/default config. Stopping
  # here lets the SSL-bump bootstrap + `systemctl start squid` later in
  # runcmd come up cleanly on the final config.
  #
  # Note: we intentionally do NOT run `squid -z -N` here. An earlier
  # revision did, on the theory that pre-initializing the swap dirs
  # would speed up first start — but `squid -z` also parses the full
  # config (including yuruna.conf), which FATALs on the missing ca.pem
  # and exits without touching /var/spool/squid. squid then initializes
  # the swap dirs on its first real start anyway, so the pre-init was
  # dead code that only polluted the log with a scary FATAL.
  - systemctl stop squid || true
  # --- SSL-bump bootstrap: self-signed CA + per-hostname cert DB that
  # squid's sslcrtd helper uses to mint leaf certs on the fly. Both
  # steps idempotent (file/dir checks) so a cloud-init re-run does NOT
  # rotate the CA -- that would orphan every guest that trusted the
  # previous one.
  #
  # CA private key stays inside this VM only (/etc/squid/ssl_cert/ is
  # proxy:proxy 700). Public cert is copied to /var/www/html/ below so
  # Apache serves it to guests over plain HTTP.
  #
  # CN embeds hostname + build timestamp so deliberate rebuilds produce
  # distinct CNs -- obvious in browsers / `openssl x509` dumps which
  # cache instance signed a given leaf.
  - |
    set -e
    CA_DIR=/etc/squid/ssl_cert
    if [ ! -f "$CA_DIR/ca.pem" ]; then
      mkdir -p "$CA_DIR"
      # -addext (self-contained) instead of -extensions v3_ca: on the
      # installed openssl 3.x the global /etc/ssl/openssl.cnf may not
      # carry [ v3_ca ], and the resulting cert (without
      # basicConstraints=CA:true) loads but Squid rejects with "No
      # valid signing certificate configured for HTTP_port [::]:3129"
      # and never binds the port. keyCertSign is required for the
      # ssl-bump per-host leaf minting.
      openssl req -new -newkey rsa:2048 -sha256 -days 3650 -nodes -x509 \
        -addext "basicConstraints=critical,CA:true" \
        -addext "keyUsage=critical,digitalSignature,cRLSign,keyCertSign" \
        -addext "subjectKeyIdentifier=hash" \
        -keyout "$CA_DIR/ca.key" \
        -out   "$CA_DIR/ca.pem" \
        -subj  "/CN=yuruna-squid-cache $(hostname) $(date -u +%Y%m%dT%H%M%SZ)"
      chown -R proxy:proxy "$CA_DIR"
      chmod 700 "$CA_DIR"
      chmod 600 "$CA_DIR/ca.key"
      chmod 644 "$CA_DIR/ca.pem"
    fi
  # security_file_certgen's `-c` is create-new; it errors if the DB
  # already exists, so the existence check guards re-runs. DB holds
  # leaf certs squid generates per SNI hostname; 4 MB is generous for
  # a single-host dev cache (each entry ~1 KB).
  #
  # The `install -d` for /var/lib/squid is NOT redundant: on Noble the
  # squid-openssl postinst does NOT guarantee that directory, and
  # security_file_certgen's Create() makes only the leaf ssl_db/ dir,
  # not its parent. Without this, the helper FATALs "Cannot create
  # /var/lib/squid/ssl_db", squid launches anyway, sslcrtd children
  # crash-loop, squid bails "The sslcrtd_program helpers are crashing
  # too rapidly, need help!" and squid-parent blocks restart for 3600s.
  # Running the helper as `proxy` avoids a follow-up chown.
  - |
    set -e
    SSL_DB=/var/lib/squid/ssl_db
    install -d -o proxy -g proxy -m 0750 /var/lib/squid
    if [ ! -d "$SSL_DB" ]; then
      sudo -u proxy /usr/lib/squid/security_file_certgen -c -s "$SSL_DB" -M 4MB
    fi
  - systemctl enable squid
  - systemctl start squid
  # --- cachemgr.cgi monitoring ---
  # a2enmod cgi wires mod_cgi; a2enconf enables the RFC1918 ACL dropin
  # above. Squid's default conf already has
  # `http_access allow manager localhost` + `deny manager`, so manager
  # queries from 127.0.0.1 (Apache) succeed while remote mgr: URLs are
  # rejected -- no extra squid ACL work needed.
  - a2enmod cgi
  - a2enconf yuruna-cachemgr
  # Publish CA public cert at http://<cache>/yuruna-squid-ca.crt for
  # guest trust-distribution. Only the public cert is copied; ca.key
  # stays inside /etc/squid/ssl_cert/. Intentionally world-readable
  # under /var/www/html/; RFC1918 reachability is enforced at the
  # network layer (UTM Shared NAT), not by Apache ACL here.
  - install -m 0644 /etc/squid/ssl_cert/ca.pem /var/www/html/yuruna-squid-ca.crt
  - systemctl enable apache2
  - systemctl restart apache2
  # --- Pre-warm the cache ---
  # security.ubuntu.com rate-limits linux-firmware (~330 MB) hard
  # enough that every cold guest install 429s on it. Pre-fetching it
  # through the local proxy means squid has it before any guest asks,
  # so the first-ever guest install serves from cache. HWE meta pulls
  # the kernel, modules-extra, and headers .debs alongside.
  # (arm64 ISO has no intel/amd microcode / firmware-sof-signed
  # analog; the `|| true` loop would skip amd64-only variants anyway.)
  #
  # Wait up to 60s for squid's listener. apt's postinst usually has
  # squid up by now, but start can be slow on first boot.
  - |
    for i in $(seq 1 60); do
      ss -ltn 'sport = :3128' 2>/dev/null | grep -q 3128 && break
      sleep 1
    done
    # Diagnostic net: if squid never bound :3128, dump its journal into
    # cloud-init-output.log so a `grep ERROR ...output.log` surfaces
    # the real cause (e.g. EADDRINUSE). Otherwise the host only sees
    # "can't TCP-connect to the cache" with no reason.
    if ! ss -ltn 'sport = :3128' 2>/dev/null | grep -q 3128; then
      echo "=== YURUNA: squid did not bind :3128 within 60s ==="
      systemctl --no-pager -l status squid || true
      journalctl --no-pager -u squid -n 80 || true
    fi
  # Only NOW route this VM's own apt through the local squid -- squid
  # is confirmed listening, so the self-proxy loop is safe. Writing
  # this file earlier would have (and did) made apt try to fetch squid
  # itself through a proxy that didn't exist yet.
  - echo 'Acquire::http::Proxy "http://127.0.0.1:3128";' > /etc/apt/apt.conf.d/99yuruna-prewarm-proxy
  - apt-get update
  # Try --reinstall --download-only first (re-fetches already-installed
  # packages like linux-firmware); fall back to plain --download-only
  # for packages not yet installed (linux-generic-hwe-24.04 on a
  # minimal server image). `|| true` on the fallback.
  - |
    for pkg in linux-firmware linux-generic-hwe-24.04; do
      echo "=== yuruna prewarm: $pkg ==="
      apt-get install --download-only --reinstall -y "$pkg" 2>/dev/null \
        || apt-get install --download-only -y "$pkg" 2>/dev/null \
        || echo "yuruna prewarm: skipped $pkg"
    done
  # Clear /var/cache/apt (squid's store is separate) to reclaim ~1 GB.
  - apt-get clean
  # Remove the apt proxy dropin so future apt usage inside THIS VM
  # doesn't loop through its own squid. Guests keep using :3128 normally.
  - rm -f /etc/apt/apt.conf.d/99yuruna-prewarm-proxy
  # --- Flip to offline_mode now that prewarm is done. offline_mode on
  # means cache hits return stored content, cache misses return 504 --
  # no origin contact. That's what enables "fully disconnected if
  # everything needed is cached": guests apt-install against this proxy
  # with no internet on the host.
  #
  # Must flip AFTER prewarm (a cold-cache request under offline_mode
  # would 504 and prewarm would populate nothing). Separate conf.d
  # file so an operator can refresh against origin by removing this
  # file and running `squid -k reconfigure`.
  - |
    cat > /etc/squid/conf.d/yuruna-offline.conf << 'EOF'
    # Serve only from cache; never contact origin. Miss returns 504.
    # To refresh: delete this file and `squid -k reconfigure`.
    offline_mode on
    EOF
  - squid -k reconfigure
  # Single-quoted: the bare `: ` would make YAML parse the scalar as
  # a mapping. Cloud-init's shellify() chokes on a dict in runcmd and
  # aborts the ENTIRE runcmd phase -- which happened once and left a
  # VM with Apache default page, no cachemgr, no offline_mode, no
  # monitoring -- even though write_files and packages had run.
  - 'echo "squid-cache offline_mode ON - serving cached content only"'
  # --- Build and install squid-exporter. No apt package and no stable
  # GitHub release-asset URL; `go install` is the only reliable cross-
  # arch path (amd64 on Hyper-V, arm64 on UTM). Pinned to v1.10.5 for
  # reproducible boots. Runs AFTER the prewarm proxy cleanup so the Go
  # module fetch (HTTPS to proxy.golang.org, GitHub) doesn't traverse
  # squid -- squid can't cache HTTPS without SSL-bump.
  - |
    export GOPATH=/root/go HOME=/root
    if /usr/bin/go install github.com/boynux/squid-exporter@v1.10.5; then
        install -m 0755 /root/go/bin/squid-exporter /usr/local/bin/squid-exporter
        echo "yuruna: squid-exporter installed at /usr/local/bin/squid-exporter"
    else
        echo "=== YURUNA: squid-exporter build failed — Grafana squid panels will stay empty until the binary is provided by hand ==="
    fi
    rm -rf /root/go
  # Reclaim ~400 MB: Go toolchain is only needed for the build above.
  # squid-exporter is a static binary that runs without Go.
  - DEBIAN_FRONTEND=noninteractive apt-get purge -y golang-go || true
  - DEBIAN_FRONTEND=noninteractive apt-get autoremove -y
  # --- Start the monitoring stack. daemon-reload picks up the
  # squid-exporter unit + grafana-server drop-in from write_files.
  # Grafana is restarted (not just enabled) so the anonymous-Viewer
  # env vars take effect even if the deb's postinst already started it.
  - systemctl daemon-reload
  - systemctl enable --now squid-exporter.service
  - systemctl enable --now prometheus.service
  - systemctl enable grafana-server.service
  - systemctl restart grafana-server.service
  # Wait for grafana-server to bind :3000 and dump its journal if it
  # doesn't. On a slow first boot grafana can take ~15s to come up
  # after `restart` returns. Without this check, a failed start is
  # only visible when an operator tries the dashboard and gets
  # "connection refused" -- by which time cloud-init logs may be
  # rotated. Matches the :3128 diagnostic net earlier in runcmd so
  # both failure modes surface in /var/log/cloud-init-output.log.
  - |
    for i in $(seq 1 60); do
      systemctl is-active --quiet grafana-server.service && \
        ss -ltn 'sport = :3000' 2>/dev/null | grep -q 3000 && break
      sleep 1
    done
    if ! systemctl is-active --quiet grafana-server.service; then
      echo "=== YURUNA: grafana-server did not become active within 60s ==="
      systemctl --no-pager -l status grafana-server.service || true
      journalctl --no-pager -u grafana-server.service -n 80 || true
    fi
  # --- Loki + Promtail. The proxy group exists by now (squid-openssl
  # was in `packages:`), so daemon-reload + restart picks up the
  # SupplementaryGroups=proxy drop-in written above; promtail can then
  # read /var/log/squid/access.log. Without the restart, promtail keeps
  # running with the unit definition cached at deb-postinst time (when
  # systemd may have started it before the proxy group existed) and
  # logs "permission denied" on every poll — Grafana panel stays empty.
  #
  # `install -d` (no -g, since there's no `promtail` / `loki` group —
  # see the drop-in comment) creates the per-service state dirs that
  # the debs' postinsts don't reliably create:
  #   /var/lib/promtail  — positions.yaml lives here.
  #   /var/lib/loki      — Loki's `path_prefix` from /etc/loki/config.yml.
  # Loki crashes on startup with `mkdir /var/lib/loki: permission denied`
  # if the dir doesn't exist, since /var/lib is root:root and the loki
  # user can't create new top-level entries. systemd retries 19x and
  # gives up ("Start request repeated too quickly"); promtail then
  # silently retries POST /loki/api/v1/push forever and the dashboard
  # panel stays empty. `reset-failed` clears the rate-limit before our
  # restart so the unit can come up cleanly.
  - install -d -o promtail -m 0755 /var/lib/promtail
  - install -d -o loki -m 0755 /var/lib/loki
  - systemctl daemon-reload
  - systemctl reset-failed loki.service promtail.service
  - systemctl enable --now loki.service
  - systemctl enable --now promtail.service
  - systemctl restart loki.service promtail.service
  # Verify promtail picked up the drop-in. Log a clear breadcrumb to
  # cloud-init-output.log if not — the Grafana panel emptiness is
  # otherwise silent and only surfaces hours later when an operator
  # notices "no data".
  - |
    sleep 2
    if ! systemctl show -p SupplementaryGroups promtail.service | grep -q proxy; then
      echo "=== YURUNA: promtail.service did not pick up SupplementaryGroups=proxy — Recent 100 requests panel will stay empty ==="
      systemctl --no-pager -l status promtail.service || true
      journalctl --no-pager -u promtail.service -n 20 || true
    fi
  - |
    vm_ip=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
    echo "=== YURUNA monitoring ==="
    echo "  Grafana:    http://${vm_ip}:3000 (anonymous Viewer — no login required)"
    echo "  Prometheus: http://127.0.0.1:9090 (loopback only — scrape via Grafana)"
    echo "  Loki:       http://127.0.0.1:3100 (loopback only — scrape via Grafana)"
    echo "  cachemgr:   http://${vm_ip}/cgi-bin/cachemgr.cgi (raw cachemgr fallback)"
    echo "  CA cert:    http://${vm_ip}/yuruna-squid-ca.crt (trust to enable :3129 HTTPS caching)"
  # Single-quoted for the colon-space trap: bare `: ` after "ready"
  # makes YAML parse the scalar as a mapping, cloud-init's shellify()
  # gets a dict instead of a string, and aborts the ENTIRE runcmd
  # phase -- nothing runs. Silent in systemctl (write_files still
  # ran); only `cloud-init status --long` surfaces the TypeError.
  - 'echo "squid-cache ready: :3128 HTTP + CONNECT, :3129 HTTPS SSL-bump (pre-warmed)"'
