#cloud-config
autoinstall:
  version: 1
  # apt.proxy (scoped — not top-level `proxy:`) routes only apt/apt-get
  # through the local squid-cache when one is running. Scope matters: the
  # top-level `proxy:` also exports http_proxy/https_proxy into late-
  # commands' env, which previously broke late-command `wget https://...`
  # calls against proxies that refused CONNECT. apt-scoped proxy avoids
  # that. The block is injected by New-VM.ps1 only when a squid-cache VM
  # is reachable at creation time; otherwise it stays absent and subiquity
  # fetches packages direct from Ubuntu mirrors.
  #
  # Why this matters for kernel install specifically: subiquity's
  # `apt-get --download-only linux-generic-hwe-24.04` step ran before any
  # of our late-commands, so under the old apt-cacher-ng setup those
  # packages went direct — and security.ubuntu.com's 429 rate limit
  # periodically failed the install (especially on macOS UTM, where every
  # VM shares the host's public IP behind Apple Virtualization's Shared
  # NAT and trips the CDN limit faster than Hyper-V). apt.proxy is applied
  # before the kernel step, so those downloads now flow through squid and
  # are cacheable across subsequent installs.
APT_PROXY_BLOCK_PLACEHOLDER
  locale: en_US.UTF-8
  keyboard:
    layout: us
  packages:
    - console-setup
    - keyboard-configuration
  identity:
    hostname: HOSTNAME_PLACEHOLDER
    username: ubuntu
    password: "HASH_PLACEHOLDER"
  storage:
    layout:
      name: lvm
  # Pin the kernel to linux-generic. Ubuntu Desktop 24.04 defaults to the
  # HWE meta-package linux-generic-hwe-24.04, which lives in noble-updates
  # — NOT on the installer cdrom. During curtin's install_kernel step the
  # target chroot's sources.list still only references file:/cdrom (the
  # network-mirror rewrite curtin does earlier doesn't reach the chroot at
  # this point), so `apt-get install --download-only linux-generic-hwe-24.04`
  # returns "Unable to locate package" and fails the install. linux-generic
  # ships on the cdrom, so the step succeeds without network round-trip.
  kernel:
    package: linux-generic
  ssh:
    allow-pw: true
  # ssh.install-server intentionally omitted: the Ubuntu Desktop ISO ships no
  # openssh-server package on /cdrom, and during install subiquity's target
  # apt only sees file:/cdrom (the http mirror it configures applies post-
  # install, not to subiquity's own package step). Setting install-server: true
  # therefore fails the install with "openssh-server has no installation
  # candidate". We install openssh-server on first boot via cloud-init's
  # packages: list below — by then 99yuruna-apt-cache is in place and the
  # download flows through the apt-cache proxy.
  # Pass-through cloud-init for the INSTALLED target. Subiquity does not parse
  # this block; it copies it to the installed system, where cloud-init runs it
  # on first boot. Top-level ssh_authorized_keys attaches to the default user
  # (ubuntu) after subiquity has committed the identity section, which avoids
  # the earlier failure modes where ssh.authorized-keys or raw SSH-related
  # late-commands silently broke identity application.
  user-data:
    ssh_authorized_keys:
      - SSH_AUTHORIZED_KEY_PLACEHOLDER
    package_update: true
    packages:
      - openssh-server
  # Sources.list override for the target lives in New-VM.ps1's
  # APT_PROXY_BLOCK (apt.sources.yuruna-ports) — curtin writes
  # /etc/apt/sources.list.d/yuruna-ports.list (legacy one-liner format)
  # during its apt-config stage, synchronously, before any in-target apt-get
  # runs. On noble 24.04 BOTH
  # Server and Desktop ISO base squashfs ship ubuntu.sources cdrom-only and
  # curtin's primary modifymirrors step can only rewrite existing URIs (not
  # add one), so apt would otherwise never reach the network mirror. See
  # guest.ubuntu.server/vmconfig/user-data header for the full rationale.
  # Desktop's install-time packages list is cdrom-only today (ubuntu-desktop
  # itself ships inside the Desktop squashfs), so the apt.sources entry is
  # currently a no-op for the Desktop install path — but it leaves the
  # installed system's sources.list.d/ pointing at ports.ubuntu.com so the
  # first-boot cloud-init `openssh-server` pull and every subsequent apt
  # invocation on the running guest goes through the configured proxy
  # (99yuruna-apt-cache) and the correct network mirror. An earlier revision
  # ran a background early-commands watcher that raced to overwrite
  # ubuntu.sources; the race lost on arm64 Server (observed install failure)
  # and the watcher is gone.
  late-commands:
    # --- Apt cache: persist proxy into the installed system ---
    # Belt-and-suspenders with autoinstall.apt.proxy: subiquity already
    # writes an apt proxy config into the target when apt.proxy is set,
    # but we explicitly write 99yuruna-apt-cache so (a) the file name is
    # predictable for debugging, and (b) behavior is unchanged if
    # subiquity's apt-persistence logic ever drifts.
    # New-VM.ps1 substitutes CACHING_PROXY_URL_PLACEHOLDER with either the
    # detected URL (e.g. http://192.168.64.x:3128) or the empty string. On
    # empty, [ -n "" ] is false and the file is not created. On hit, every
    # post-install apt-get in the guest (cloud-init's first-boot
    # openssh-server install, test-workload, VS Code, .NET SDK, Kubernetes
    # packages, etc.) flows through the cache.
    - |
      if [ -n "CACHING_PROXY_URL_PLACEHOLDER" ]; then
        echo 'Acquire::http::Proxy "CACHING_PROXY_URL_PLACEHOLDER";' > /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        chmod 0644 /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        # --- HTTPS caching opt-in (macOS host path) ---
        # Windows hyper-v guest.ubuntu.* user-data fetches the CA inside
        # the installer via wget because guests reach the cache VM
        # directly on the Default Switch. On macOS the guest cannot
        # fetch from a co-tenant VM — Apple VZ shared-NAT isolates
        # guests — so guest.ubuntu.*/New-VM.ps1 on the HOST fetches the
        # CA at provision time and base64-embeds it here via
        # CA_CERT_BASE64_PLACEHOLDER.
        #
        # Acquire::https::Proxy points at the :3129 ssl-bump listener
        # on the SAME host as the HTTP proxy (derived from
        # CACHING_PROXY_URL_PLACEHOLDER). The guest reaches it over the
        # standard shared-NAT route that the HTTP side already proves
        # works. Earlier revisions hardcoded 192.168.64.1:3129 assuming
        # a host-side forwarder created by Start-CachingProxy.ps1; that
        # forwarder only exists when squid runs on THIS macOS host, not
        # when the cache is a LAN peer — and in the peer case every
        # HTTPS apt call died with "Connection refused," silently
        # aborting the Docker install downstream. If the CA fetch
        # failed or was skipped CA_CERT_BASE64_PLACEHOLDER comes
        # through empty and this block becomes a no-op — HTTPS apt
        # bypasses the cache and goes direct (same as before ssl-bump).
        if [ -n "CA_CERT_BASE64_PLACEHOLDER" ]; then
          mkdir -p /target/usr/local/share/ca-certificates
          printf '%s' "CA_CERT_BASE64_PLACEHOLDER" | base64 -d > /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
          chmod 0644 /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
          curtin in-target --target=/target -- update-ca-certificates
          CACHE_HOST=$(echo "CACHING_PROXY_URL_PLACEHOLDER" | sed -E 's|^https?://([^:/]+).*|\1|')
          echo "Acquire::https::Proxy \"http://${CACHE_HOST}:3129\";" >> /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        fi
      fi
    # --- Cap systemd-networkd-wait-online so first boot doesn't hang ---
    # See guest.ubuntu.server/vmconfig/user-data for the full rationale.
    # Short version: Ubuntu 24.04 default is "wait for ALL interfaces to
    # reach routable with no timeout", which on Apple Virtualization's
    # shared NAT blocks forever on a non-arriving IPv6 RA. --any --timeout=30
    # caps it.
    - mkdir -p /target/etc/systemd/system/systemd-networkd-wait-online.service.d
    - |
      cat > /target/etc/systemd/system/systemd-networkd-wait-online.service.d/override.conf << 'EOF'
      [Service]
      ExecStart=
      ExecStart=/lib/systemd/systemd-networkd-wait-online --any --timeout=15
      EOF
    # --- Security: user account ---
    - curtin in-target --target=/target -- passwd --expire ubuntu
    # --- SSH: install yuruna test-harness authorized key for the ubuntu user ---
    # Single curtin-in-target command, mirroring the passwd --expire pattern that
    # has always been safe. Previous attempts using either autoinstall.ssh.authorized-keys
    # or multi-line raw shell late-commands silently broke subiquity's identity
    # application (empty /etc/shadow). This form runs in the installed target
    # chroot after identity is committed, keeping the install path untouched.
    - curtin in-target --target=/target -- bash -c 'install -d -m 700 -o ubuntu -g ubuntu /home/ubuntu/.ssh && echo "SSH_AUTHORIZED_KEY_PLACEHOLDER" > /home/ubuntu/.ssh/authorized_keys && chmod 600 /home/ubuntu/.ssh/authorized_keys && chown ubuntu:ubuntu /home/ubuntu/.ssh/authorized_keys'
    # --- Sudo: grant the ubuntu user passwordless sudo for the test harness ---
    # Needed so the SSH-driven workload can invoke /automation/fetch-and-execute.sh
    # with sudo (no TTY, no askpass under BatchMode). Dropped as a sudoers.d file
    # with 0440 perms per sudo's requirements.
    - curtin in-target --target=/target -- bash -c 'echo "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/90-yuruna-ubuntu && chmod 440 /etc/sudoers.d/90-yuruna-ubuntu && chown root:root /etc/sudoers.d/90-yuruna-ubuntu'
    # --- System: disable swap ---
    - sed -i '/ swap / s/^/#/' /target/etc/fstab
    - curtin in-target --target=/target -- systemctl mask swap.target
    # --- System: disable MOTD ---
    - chmod -x /target/etc/update-motd.d/*
    - mkdir -p /target/etc/default && test -f /target/etc/default/motd-news && sed -i 's/^ENABLED=1/ENABLED=0/' /target/etc/default/motd-news || echo 'ENABLED=0' > /target/etc/default/motd-news
    # --- GNOME: skip initial setup ---
    - curtin in-target --target=/target -- mkdir -p /etc/skel/.config
    - echo 'yes' > /target/etc/skel/.config/gnome-initial-setup-done
    - curtin in-target --target=/target -- mkdir -p /home/ubuntu/.config
    - echo 'yes' > /target/home/ubuntu/.config/gnome-initial-setup-done
    - curtin in-target --target=/target -- chown -R ubuntu:ubuntu /home/ubuntu/.config
    # --- GNOME: auto-open terminal on login ---
    - curtin in-target --target=/target -- mkdir -p /etc/xdg/autostart
    - |
      cat > /target/etc/xdg/autostart/open-terminal.desktop << 'DESKTOP'
      [Desktop Entry]
      Type=Application
      Name=Open Terminal
      Exec=gnome-terminal
      X-GNOME-Autostart-enabled=true
      NoDisplay=true
      DESKTOP
    # --- IBus: stub out ibus-daemon to avoid the gdm greeter input-method race ---
    # On Ubuntu 24.04 + GNOME 46, the gdm greeter's gnome-shell spawns two
    # ibus-daemon instances back-to-back: one normal, then one with
    # "-r --xim" that replaces the first to add XIM support for Xwayland.
    # The replace handshake orphans gnome-shell's InputContext D-Bus proxy.
    # Every subsequent key press to a greeter text entry calls
    # org/freedesktop/IBus/InputContext_N.ProcessKeyEvent on the dead path,
    # gets UnknownMethod, and is silently swallowed by gnome-shell's IM
    # filter. The login fields look focused but accept no input, while
    # Enter/Tab/Escape and tty switches still work (those bypass the IM
    # filter). Setting GTK_IM_MODULE/QT_IM_MODULE was verified NOT to help:
    # gnome-shell's Wayland IM layer uses libibus directly, bypassing the
    # GTK module abstraction. The only reliable fix is to prevent
    # ibus-daemon from running at all. Divert the real binary and symlink
    # to /bin/true so gnome-shell's exec returns immediately; gnome-shell
    # then proceeds without an IBus backend and key events reach text
    # entries via the direct libinput → mutter → clutter path. For yuruna
    # test VMs (ASCII passwords and shell commands only) losing IBus is a
    # non-issue. dpkg-divert survives apt upgrades.
    - curtin in-target --target=/target -- dpkg-divert --local --add --rename /usr/bin/ibus-daemon
    - curtin in-target --target=/target -- ln -sf /bin/true /usr/bin/ibus-daemon
    # --- GNOME: enable automatic timezone (requires dconf) ---
    - mkdir -p /target/etc/dconf/db/local.d
    - |
      cat > /target/etc/dconf/db/local.d/00-timezone << 'DCONF'
      [org/gnome/desktop/datetime]
      automatic-timezone=true

      [org/gnome/system/location]
      enabled=true
      DCONF
    # --- GDM greeter: never blank the display ---
    # ubuntu.desktop.update.sh disables idle/lock for the ubuntu USER, but
    # that profile does NOT apply to the GDM greeter — which runs under the
    # `gdm` system-db profile. With the default idle-delay, the greeter
    # blanks after ~3 min, hypervisor screen captures return pure black, OCR
    # extracts no text, and Test-Workload step 1 ("Not listed?") times out
    # even though the greeter would render correctly if anyone touched the
    # VM. A dconf drop-in in /etc/dconf/db/gdm.d/ + dconf update is the
    # Canonical-documented way to override greeter settings at install time.
    - mkdir -p /target/etc/dconf/db/gdm.d
    - |
      cat > /target/etc/dconf/db/gdm.d/99-yuruna-no-idle << 'DCONF'
      [org/gnome/desktop/session]
      idle-delay=uint32 0

      [org/gnome/settings-daemon/plugins/power]
      sleep-inactive-ac-type='nothing'
      sleep-inactive-battery-type='nothing'
      idle-dim=false
      power-button-action='nothing'

      [org/gnome/desktop/screensaver]
      lock-enabled=false
      idle-activation-enabled=false
      DCONF
    - curtin in-target --target=/target -- dconf update
    # --- System: denylist hv_balloon to prevent console messages ---
    - |
      cat > /target/etc/modprobe.d/denylist-hv-balloon.conf << 'MODPROBE'
      blacklist hv_balloon
      MODPROBE
    # --- Network: download fetch-and-execute utility ---
    - mkdir -p /target/automation
    - wget --no-cache -O /target/automation/fetch-and-execute.sh "https://raw.githubusercontent.com/alissonsol/yuruna/refs/heads/main/automation/fetch-and-execute.sh"
    - curtin in-target --target=/target -- chmod +x /automation/fetch-and-execute.sh
    # --- Network: timezone detection via IP geolocation and NTP ---
    - curtin in-target --target=/target -- timedatectl set-ntp true
    - curtin in-target --target=/target -- bash -c 'command -v wget >/dev/null 2>&1 && TZ=$(wget -qO - --timeout=5 "http://ip-api.com/line?fields=timezone") && [ -n "$TZ" ] && timedatectl set-timezone "$TZ" || echo "Yuruna => Timezone sync failed (check wget, network, or API)" >&2'
