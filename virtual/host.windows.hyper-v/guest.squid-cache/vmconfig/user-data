package_update: true
packages:
  # squid-openssl: OpenSSL-linked build. Ubuntu Noble's default `squid`
  # package is built WITHOUT --with-openssl (Debian packaging split over
  # OpenSSL vs GPL licensing), so its http_port parser rejects `ssl-bump`,
  # `tls-cert=`, etc. with a "Bungled" FATAL at config-load and
  # squid.service never binds a socket. squid-openssl ships the same
  # /usr/sbin/squid and squid.service unit, and Conflicts: squid.
  - squid-openssl
  # squid-cgi provides cachemgr.cgi, hosted by apache2 (cgi-bin/ is wired
  # up by the default conf.d/serve-cgi-bin.conf once runcmd enables
  # mod_cgi). Low-overhead fallback to the Prometheus+Grafana UI for raw
  # cachemgr queries.
  - squid-cgi
  # squidclient (/usr/bin/squidclient) — cache-manager queries + PURGE.
  # Ships in squid-common, which squid-openssl already pulls in, so no
  # additional package needed. A previous entry `- squid-cli` was based
  # on a wrong assumption (no such package on noble): cloud-init's
  # dpkg-verify post-install check raised, marking the packages module
  # as failed and leaving `cloud-init status` in `error` for the lifetime
  # of the instance. From any RFC1918 host:
  #   curl -x http://<cache>:3128 -X PURGE http://<origin>:<port>/<path>
  - apache2
  # Monitoring stack: Prometheus scrapes squid-exporter (localhost:9301);
  # Grafana on :3000 (anonymous Viewer). squid-exporter has no apt package
  # and no stable GitHub release-asset URL, so golang-go is pulled in just
  # long enough to `go install` it; both build tools are purged at the end
  # of runcmd (~400 MB reclaimed). The compiled binary stays.
  #
  # loki + promtail back the "Last 100 requests" Grafana panel — Prometheus
  # only stores aggregates, so per-request client IP / target URL are not
  # available there. Promtail tails /var/log/squid/access.log and ships to
  # Loki on localhost:3100. Both come from apt.grafana.com (same repo as
  # grafana) — no extra source needed.
  - prometheus
  - grafana
  - loki
  - promtail
  - golang-go
  # Network debugging tools for interactive triage via console/SSH.
  # Noble's server cloud image ships `ip` but not `ifconfig` or `ping`;
  # cheap to install, big quality-of-life win.
  - net-tools       # ifconfig, netstat, route, arp
  - iputils-ping    # ping, ping6
  # openssl for the CA-generation step in runcmd. The cloud image ships
  # libssl but not the /usr/bin/openssl CLI, so `req -x509` would fail
  # with "command not found" and leave squid's http_port 3129 unable to
  # load tls-cert/tls-key. Kept top-level (not apt-get in runcmd) so
  # failure surfaces in the package-install phase, not halfway through
  # cache setup.
  - openssl
  # NOTE: hyperv-daemons (hv_kvp_daemon) is installed via runcmd with
  # `|| true`, not here. Its dep on linux-cloud-tools-$(uname -r) matching
  # the running cloud-image kernel isn't always satisfiable until a fresh
  # `apt-get update` lands, and a hard failure was aborting the ENTIRE
  # packages phase (grafana/prometheus/squid included). If hv-kvp-daemon
  # doesn't come up, Get-VMNetworkAdapter on the host returns empty and
  # discovery falls back to ARP — slower but works.
write_files:
  # Retry apt fetches on transient network errors. Cloud-init's default is
  # one-shot; a single timeout or TCP reset against archive.ubuntu.com
  # fails the whole package install and leaves the VM without squid — the
  # exact "Exit code: 100 / Stdout: -" failure seen against `apt-get
  # install apache2 squid`. Retries=5 covers transient hiccups; does NOT
  # paper over 4xx (429/404) — apt treats those as fatal and they need
  # operator attention via /var/log/cloud-init-output.log.
  - path: /etc/apt/apt.conf.d/80-yuruna-retries
    permissions: '0644'
    owner: root:root
    content: |
      Acquire::Retries "5";
      Acquire::Retries::Delay-Max "60";
  # NOTE: the 99yuruna-prewarm-proxy apt dropin used to live here — a
  # bootstrap bug. write_files runs BEFORE the `packages:` apt install, so
  # if the dropin exists at install time, apt tries to fetch squid itself
  # through 127.0.0.1:3128, fails ("Unable to connect..."), and the whole
  # install bombs (Exit code 100) with squid never installed. The dropin
  # is now written LATER in runcmd, only after squid is listening on :3128.
  # Restrict cachemgr.cgi to RFC1918, matching the squid ACL. Apache's
  # default cgi-bin/ is open to all; in practice the VM is only reachable
  # from Hyper-V's Default Switch, but aligning policy with squid means a
  # misconfigured host network can't accidentally expose cachemgr.
  - path: /etc/apache2/conf-available/yuruna-cachemgr.conf
    permissions: '0644'
    owner: root:root
    content: |
      <Location /cgi-bin/cachemgr.cgi>
          Require ip 127.0.0.1
          Require ip 10.0.0.0/8
          Require ip 172.16.0.0/12
          Require ip 192.168.0.0/16
      </Location>
  # Drop-in overrides on top of Ubuntu's stock /etc/squid/squid.conf.
  # conf.d files include after the main config so same-named directives
  # here win. Keeping this a drop-in (not a full replacement) means future
  # squid package upgrades still get their default refresh_pattern and ACL
  # baseline — we only override what's specific to yuruna.
  - path: /etc/squid/conf.d/yuruna.conf
    permissions: '0644'
    owner: root:root
    content: |
      # yuruna squid-cache — generic HTTP proxy/cache for test-VM installs.
      # Replaces apt-cacher-ng, which only cached .deb URLs and still let
      # security.ubuntu.com 429s bubble up to subiquity (its pre-install
      # kernel fetch went direct). Squid caches any cacheable HTTP
      # response, so the installer's own apt-get --download-only of
      # linux-firmware etc. hits cache on subsequent installs.

      # NOTE: do NOT declare `http_port 3128` here. Ubuntu's stock
      # /etc/squid/squid.conf already declares it, and /etc/squid/conf.d/*
      # is INCLUDED (not overlaid) — a duplicate makes squid try to bind
      # twice, the second fails with EADDRINUSE ("listen ... (98) Address
      # already in use") while squid still appears 'running'. The default
      # binding (all interfaces, :3128) is what we want.

      # Permit only RFC1918 sources. Hyper-V Default Switch hands out
      # 172.x.x.x; 10/8 and 192.168/16 cover other private switches.
      acl yuruna_local src 10.0.0.0/8
      acl yuruna_local src 172.16.0.0/12
      acl yuruna_local src 192.168.0.0/16

      # --- Cache purge: enable PURGE for RFC1918 operators ---
      # squidclient -m PURGE invalidates a single cached entry without
      # reloading. Usage:
      #   From the cache VM:
      #     sudo squidclient -m PURGE http://<origin>:<port>/<path>
      #   From any RFC1918 workstation:
      #     curl -x http://<cache>:3128 -X PURGE http://<origin>:<port>/<path>
      # Rules MUST appear before `http_access allow yuruna_local`: squid
      # walks http_access top-down, first-match-wins, and the generic
      # allow would otherwise match PURGE-from-yuruna_local before the
      # method-scoped rule — the explicit deny would become dead code, and
      # tightening later (e.g. yuruna_local → localhost) would silently do
      # nothing.
      acl yuruna_purge method PURGE
      http_access allow yuruna_purge yuruna_local
      http_access deny yuruna_purge

      http_access allow yuruna_local

      # --- Snapshot-cache tuning ---
      # Tuned as a replayable snapshot:
      #   1. objects stay until the disk is nearly full (no proactive
      #      release)
      #   2. cache keeps serving when origin is unreachable or sends
      #      cache-hostile headers
      #   3. with offline_mode (flipped by runcmd after prewarm), a full
      #      cache supports guest installs with zero internet.
      #
      # cache_replacement_policy MUST appear before cache_dir — squid
      # binds the policy at cache_dir parse time; a later override has no
      # effect. heap LFUDA keeps frequently-used large objects
      # (linux-firmware, kernels) over many small ones; GDSF does the
      # same in-memory. When eviction fires, rarely-touched small objects
      # drop first — the big expensive-to-refetch blobs survive, which is
      # what offline replay needs.
      cache_replacement_policy heap LFUDA
      memory_replacement_policy heap GDSF

      # Disk cache sized for a 144 GB VHDX: 128 GB squid + ~16 GB OS/logs.
      # ufs is fine for a single-host dev cache; switch to aufs/diskd only
      # if squid blocks on disk I/O under concurrent installs.
      cache_dir ufs /var/spool/squid 131072 16 256
      maximum_object_size 4 GB
      maximum_object_size_in_memory 32 MB
      cache_mem 512 MB

      # Never release unless forced: evict only when disk >99% full,
      # stopping at 98%. Default 90/95 would evict with ~5 GB free —
      # wrong for a sticky snapshot cache.
      cache_swap_high 99
      cache_swap_low  98

      # Don't cache failures (404, 5xx). A transient blip must not become
      # a poisoned 504 returned forever for an object squid could fetch
      # successfully next time.
      negative_ttl 0 seconds

      # Never abort partial downloads. If a client disconnects mid-fetch
      # (e.g. guest reboot), squid finishes so the next client hits
      # cache. -1 KB disables the quick-abort threshold entirely.
      quick_abort_min -1 KB

      # Package files are content-addressable (version in URL), so a new
      # version is a different URL — no value revalidating what we have.
      # override/ignore flags keep squid serving regardless of origin or
      # intermediate cache-control hints (no-store, must-revalidate,
      # private, reload-from-client). 525600 min = 1 year.
      refresh_pattern -i \.deb$      525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.udeb$     525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.tar\.xz$  525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.tar\.gz$  525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.tar\.bz2$ 525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      refresh_pattern -i \.iso$      525600 100% 525600 override-expire override-lastmod ignore-reload ignore-no-store ignore-must-revalidate ignore-private
      # Apt metadata (InRelease, Packages.*) moves — poll origin each time.
      refresh_pattern -i /InRelease$                    0 0%  60
      refresh_pattern -i /Release$                      0 0%  60
      refresh_pattern -i /Release\.gpg$                 0 0%  60
      refresh_pattern -i /Packages(\.gz|\.xz|\.bz2)?$   0 0%  60
      refresh_pattern -i /Sources(\.gz|\.xz|\.bz2)?$    0 0%  60

      logfile_rotate 2

      # --- HTTPS caching via SSL-bump (second listener on :3129) ---
      # Stock http_port 3128 stays a pure CONNECT-tunnel for HTTPS — no
      # MITM, no caching, no trust required. Keeps legacy clients and
      # subiquity's pre-install HTTPS calls (which run before our CA
      # lands in the target chroot) working as before ssl-bump existed.
      #
      # Port 3129 is the opt-in ssl-bump listener. Guests that trust
      # /etc/squid/ssl_cert/ca.pem (published at
      # http://<cache>/yuruna-squid-ca.crt by Apache below) point
      # Acquire::https::Proxy there and get HTTPS apt traffic
      # intercepted, cached, and replayed through the same
      # refresh_pattern + offline_mode pipeline as HTTP.
      #
      # peek-step1-then-bump-all: squid reads the TLS ClientHello for the
      # SNI hostname, mints a per-host leaf signed by the yuruna CA, and
      # terminates the client side. If a pin-checking client (snap, Go
      # binaries) ever hits the install path, add `acl nobump dstdomain
      # ...` + `ssl_bump splice nobump` ABOVE bump-all rather than
      # disabling bumping wholesale.
      #
      # The `step1` acl MUST be declared explicitly — squid does not
      # auto-define at_step ACLs; without it, `ssl_bump peek step1` FATALs
      # with "Bungled ... ssl_bump peek step1" and squid never binds
      # 3128/3129.
      acl step1 at_step SslBump1
      #
      # NOTE: dynamic_cert_mem_cache_size is TOP-LEVEL in Squid 6 (Noble),
      # NOT an http_port option. An earlier revision inlined it on the
      # http_port line and tripped a "Bungled" parser error that kept
      # squid from starting. 4 MB is the default; we let it stand.
      http_port 3129 ssl-bump generate-host-certificates=on tls-cert=/etc/squid/ssl_cert/ca.pem tls-key=/etc/squid/ssl_cert/ca.key
      sslcrtd_program /usr/lib/squid/security_file_certgen -s /var/lib/squid/ssl_db -M 4MB
      sslcrtd_children 5
      ssl_bump peek step1
      ssl_bump bump all

      # --- PROXY-protocol-aware listeners for the host-side userspace
      # forwarder. Without these, every connection that came through
      # netsh portproxy (or the pwsh forwarder) appeared in access.log
      # as the host's NAT-side IP because TCP forwarding rewrites the
      # source. The Test.PortMap module launches a pwsh forwarder for
      # host:3128/3129 that prepends a HAProxy PROXY v1 header; squid
      # parses it on these ports and uses the supplied client IP for
      # ACLs and access.log.
      #
      # NOTE: option name is `require-proxy-header` in Squid 6 (Noble),
      # NOT `accept-proxy-protocol` (the squid 4 / older-docs name).
      # Using the old name FATALs at parse:
      #   "Unknown http_port option 'accept-proxy-protocol'"
      # Same semantics either way — every connection on the port MUST
      # start with a PROXY v1 (or v2) header.
      #
      # Separate ports (not the same 3128/3129) because require-proxy-header
      # mandates a PROXY header — local Default-Switch guests that
      # connect directly without one still hit 3128/3129.
      #
      # proxy_protocol_access controls which client IPs may send PROXY
      # headers (i.e. which proxies are trusted to vouch for client IPs).
      # Allow RFC1918 + loopback — the host forwarder lives on the
      # 172.16/12 Default Switch (RFC1918); loopback covers on-VM
      # diagnostics like `python3 -c 'socket... PROXY TCP4 ...'` against
      # 127.0.0.1:3138 to spot-check the path without a real LAN client.
      acl yuruna_proxy_senders src 10.0.0.0/8
      acl yuruna_proxy_senders src 172.16.0.0/12
      acl yuruna_proxy_senders src 192.168.0.0/16
      acl yuruna_proxy_senders src 127.0.0.1/32
      acl yuruna_proxy_senders src ::1/128
      proxy_protocol_access allow yuruna_proxy_senders
      proxy_protocol_access deny all
      http_port 3138 require-proxy-header
      http_port 3139 require-proxy-header ssl-bump generate-host-certificates=on tls-cert=/etc/squid/ssl_cert/ca.pem tls-key=/etc/squid/ssl_cert/ca.key

      # --- Custom access-log format for the Grafana "Last 100 requests"
      # panel. Adds %>A (client FQDN) between %>a (IP) and the status
      # token so the panel can render hostname when reverse DNS resolves.
      # %<st (response bytes) was already in the default `squid` format —
      # it's now explicitly captured by the dashboard's regex, so the
      # panel can show transfer size between status and URL.
      #
      # In Squid 6 (Noble), %>A triggers the synchronous PTR lookup
      # itself — the old `log_fqdn on` global is OBSOLETE and emits
      # "Directive 'log_fqdn' is obsolete" at parse time. Don't add it.
      # On a PTR miss, %>A falls back to the IP literal (NOT "-"), so
      # the field is always populated and the regex never fails to match.
      #
      # Output goes to a SEPARATE file (yuruna_access.log) — the default
      # access.log keeps its stock `squid` format for cachemgr.cgi and
      # manual `tail -f /var/log/squid/access.log` debugging. Two squid
      # access_log entries writing the same file would interleave bytes
      # and corrupt both formats.
      logformat yuruna %ts.%03tu %6tr %>a %>A %Ss/%03>Hs %<st %rm %ru %[un %Sh/%<a %mt
      access_log /var/log/squid/yuruna_access.log yuruna
  # --- Prometheus: bind loopback only; Grafana scrapes via localhost.
  # Keeps Prometheus's open-access UI off the LAN — Grafana on :3000 is
  # the only exposed entry point.
  - path: /etc/default/prometheus
    permissions: '0644'
    owner: root:root
    content: |
      ARGS="--web.listen-address=127.0.0.1:9090"
  - path: /etc/prometheus/prometheus.yml
    permissions: '0644'
    owner: root:root
    content: |
      global:
        scrape_interval: 15s
      scrape_configs:
        - job_name: prometheus
          static_configs:
            - targets: ['localhost:9090']
        - job_name: squid
          static_configs:
            - targets: ['localhost:9301']
  # --- Loki: log datastore for the access-log panel. Loopback-only;
  # Grafana scrapes via localhost. Single-binary monolithic config with
  # filesystem TSDB — no object store, no extra services. Retention capped
  # at 7d (compactor enabled) so /var/lib/loki doesn't grow unbounded for
  # what's effectively a "last 100 requests" UX.
  #
  # Pre-written via write_files; the loki deb's postinst respects
  # cloud-init's --force-confold and keeps this file. Without explicit
  # http_listen_address the deb default is 0.0.0.0 — same exposure issue
  # as Prometheus, fixed the same way.
  - path: /etc/loki/config.yml
    permissions: '0644'
    owner: root:root
    content: |
      auth_enabled: false
      server:
        http_listen_address: 127.0.0.1
        http_listen_port: 3100
        grpc_listen_address: 127.0.0.1
        grpc_listen_port: 9096
      common:
        instance_addr: 127.0.0.1
        path_prefix: /var/lib/loki
        storage:
          filesystem:
            chunks_directory: /var/lib/loki/chunks
            rules_directory: /var/lib/loki/rules
        replication_factor: 1
        ring:
          kvstore:
            store: inmemory
      schema_config:
        configs:
          - from: 2024-01-01
            store: tsdb
            object_store: filesystem
            schema: v13
            index:
              prefix: index_
              period: 24h
      limits_config:
        retention_period: 168h
      compactor:
        working_directory: /var/lib/loki/compactor
        retention_enabled: true
        delete_request_store: filesystem
  # --- Promtail: tails /var/log/squid/access.log and ships each line to
  # Loki. Only the timestamp is parsed in promtail — keeps client IP and
  # URL out of Loki labels (high cardinality = stream explosion). The
  # Grafana panel re-parses with `regexp` at query time.
  #
  # positions.yaml on disk (not /tmp default) so reboots don't re-tail
  # the entire access.log. /var/lib/promtail is created in runcmd because
  # the deb postinst doesn't always.
  - path: /etc/promtail/config.yml
    permissions: '0644'
    owner: root:root
    content: |
      server:
        http_listen_address: 127.0.0.1
        http_listen_port: 9080
        grpc_listen_port: 0
      positions:
        filename: /var/lib/promtail/positions.yaml
      clients:
        - url: http://127.0.0.1:3100/loki/api/v1/push
      scrape_configs:
        - job_name: squid
          static_configs:
            - targets:
                - localhost
              labels:
                job: squid
                # yuruna_access.log is the custom logformat (defined in
                # /etc/squid/conf.d/yuruna.conf) that includes %>A — the
                # client FQDN — between client IP and status. The stock
                # access.log keeps its default format for cachemgr/tail
                # debugging; only Promtail tails the yuruna variant.
                __path__: /var/log/squid/yuruna_access.log
          pipeline_stages:
            - regex:
                expression: '^(?P<ts>\d+\.\d+)\s+\d+\s+'
            - timestamp:
                source: ts
                format: Unix
  # --- Promtail systemd drop-in: SupplementaryGroups=proxy so promtail
  # can read /var/log/squid/access.log (proxy:proxy 640) without
  # touching /etc/group via usermod. Declarative and survives package
  # upgrades. We can't put `Group=proxy` because the promtail deb on
  # Noble creates the user with primary group `nogroup` (its postinst
  # runs `adduser --system --group promtail` expecting an existing
  # `promtail` group; the group doesn't exist, adduser falls back to
  # nogroup, so there is no `promtail` group anywhere on the system —
  # don't reference one).
  - path: /etc/systemd/system/promtail.service.d/yuruna.conf
    permissions: '0644'
    owner: root:root
    content: |
      [Service]
      SupplementaryGroups=proxy
  # --- squid-exporter systemd unit. Binary installed via `go install` in
  # runcmd; starts on boot after network + squid. Loopback-bound —
  # Prometheus (same VM) is the only consumer.
  - path: /etc/systemd/system/squid-exporter.service
    permissions: '0644'
    owner: root:root
    content: |
      [Unit]
      Description=Squid Prometheus exporter (boynux/squid-exporter)
      After=network-online.target squid.service
      Wants=network-online.target squid.service
      [Service]
      Type=simple
      User=nobody
      Group=nogroup
      ExecStart=/usr/local/bin/squid-exporter -listen 127.0.0.1:9301 -squid-hostname localhost -squid-port 3128
      Restart=on-failure
      RestartSec=5
      [Install]
      WantedBy=multi-user.target
  # --- Grafana: anonymous Viewer so operators hit the dashboard with no
  # login (and no sign-up, no Grafana Cloud). Admin login still works
  # (default admin/admin) for editing. Standard systemd override path;
  # Grafana reads GF_* env vars natively.
  - path: /etc/systemd/system/grafana-server.service.d/yuruna.conf
    permissions: '0644'
    owner: root:root
    content: |
      [Service]
      Environment=GF_AUTH_ANONYMOUS_ENABLED=true
      Environment=GF_AUTH_ANONYMOUS_ORG_ROLE=Viewer
  # --- Grafana datasources. UIDs pinned so the dashboard below can
  # reference each by stable name without knowing Grafana's auto-UID.
  - path: /etc/grafana/provisioning/datasources/yuruna.yaml
    permissions: '0644'
    owner: root:root
    content: |
      apiVersion: 1
      datasources:
        - name: Prometheus
          uid: yuruna-prometheus
          type: prometheus
          access: proxy
          url: http://localhost:9090
          isDefault: true
          editable: false
        - name: Loki
          uid: yuruna-loki
          type: loki
          access: proxy
          url: http://localhost:3100
          editable: false
  # --- Grafana dashboard provider: scan /var/lib/grafana/dashboards for
  # JSON and import. updateIntervalSeconds keeps them in sync with
  # post-boot edits to on-disk files.
  - path: /etc/grafana/provisioning/dashboards/yuruna.yaml
    permissions: '0644'
    owner: root:root
    content: |
      apiVersion: 1
      providers:
        - name: yuruna
          folder: ''
          type: file
          disableDeletion: true
          updateIntervalSeconds: 30
          options:
            path: /var/lib/grafana/dashboards
  # --- Minimal squid dashboard. squid_client_* panels render once the
  # exporter is serving; if a metric name drifts between releases, the
  # panel shows "No data" but the rest of the dashboard still loads.
  - path: /var/lib/grafana/dashboards/squid.json
    permissions: '0644'
    owner: root:root
    content: |
      {
        "uid": "yuruna-squid",
        "title": "Squid Cache (yuruna)",
        "schemaVersion": 39,
        "version": 1,
        "refresh": "30s",
        "time": {"from": "now-2h", "to": "now"},
        "panels": [
          {
            "id": 2,
            "type": "timeseries",
            "title": "Client HTTP(S) requests/sec",
            "datasource": {"type": "prometheus", "uid": "yuruna-prometheus"},
            "gridPos": {"x": 0, "y": 0, "w": 24, "h": 6},
            "fieldConfig": {
              "defaults": {},
              "overrides": [
                {
                  "matcher": {"id": "byFrameRefID", "options": "A"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
                }
              ]
            },
            "targets": [{"expr": "rate(squid_client_http_requests_total[5m])", "refId": "A"}]
          },
          {
            "id": 3,
            "type": "timeseries",
            "title": "Client HTTP(S) hits/sec",
            "datasource": {"type": "prometheus", "uid": "yuruna-prometheus"},
            "gridPos": {"x": 0, "y": 6, "w": 24, "h": 6},
            "fieldConfig": {
              "defaults": {},
              "overrides": [
                {
                  "matcher": {"id": "byFrameRefID", "options": "A"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
                }
              ]
            },
            "targets": [{"expr": "rate(squid_client_http_hits_total[5m])", "refId": "A"}]
          },
          {
            "id": 6,
            "type": "timeseries",
            "title": "Client HTTP(S) data served (kB/s): total vs cached",
            "datasource": {"type": "prometheus", "uid": "yuruna-prometheus"},
            "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
            "fieldConfig": {
              "defaults": {},
              "overrides": [
                {
                  "matcher": {"id": "byName", "options": "Total"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
                },
                {
                  "matcher": {"id": "byName", "options": "Cached"},
                  "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
                }
              ]
            },
            "targets": [
              {"expr": "rate(squid_client_http_kbytes_out_kbytes_total[5m])",     "refId": "A", "legendFormat": "Total"},
              {"expr": "rate(squid_client_http_hit_kbytes_out_bytes_total[5m])", "refId": "B", "legendFormat": "Cached"}
            ]
          },
          {
            "id": 7,
            "type": "logs",
            "title": "Last 100 requests (client IP / hostname / status / size / URL)",
            "datasource": {"type": "loki", "uid": "yuruna-loki"},
            "gridPos": {"x": 0, "y": 20, "w": 24, "h": 12},
            "options": {
              "showTime": true,
              "showLabels": false,
              "showCommonLabels": false,
              "wrapLogMessage": false,
              "prettifyLogMessage": false,
              "enableLogDetails": true,
              "dedupStrategy": "none",
              "sortOrder": "Descending"
            },
            "targets": [
              {
                "expr": "{job=\"squid\"} | regexp `^\\S+\\s+\\S+\\s+(?P<client_ip>\\S+)\\s+(?P<client_host>\\S+)\\s+(?P<status>\\S+)\\s+(?P<bytes>\\S+)\\s+\\S+\\s+(?P<url>\\S+)` | line_format `{{.client_ip}}  {{.client_host}}  {{.status}}  {{.bytes}}  {{.url}}`",
                "refId": "A",
                "maxLines": 100
              }
            ]
          }
        ]
      }
runcmd:
  # Stop the squid that apt's postinst attempted to start — it is either
  # already FATAL (write_files dropped /etc/squid/conf.d/yuruna.conf with
  # `tls-cert=/etc/squid/ssl_cert/ca.pem` referenced before we generate
  # that cert below) or running with a partial/default config. Stopping
  # here lets the SSL-bump bootstrap + `systemctl start squid` later in
  # runcmd come up cleanly on the final config.
  #
  # Note: we intentionally do NOT run `squid -z -N` here. An earlier
  # revision did, on the theory that pre-initializing the swap dirs
  # would speed up first start — but `squid -z` also parses the full
  # config (including yuruna.conf), which FATALs on the missing ca.pem
  # and exits without touching /var/spool/squid. squid then initializes
  # the swap dirs on its first real start anyway, so the pre-init was
  # dead code that only polluted the log with a scary FATAL.
  - systemctl stop squid || true
  # --- SSL-bump bootstrap: self-signed CA + per-hostname cert DB for
  # sslcrtd to mint leaf certs on the fly. Both steps idempotent (file/dir
  # checks) so a cloud-init re-run doesn't rotate the CA — rotating would
  # orphan every guest that trusted the previous one.
  #
  # CA private key lives ONLY inside this VM (/etc/squid/ssl_cert/ is
  # proxy:proxy 700). Public cert is copied to /var/www/html/ below so
  # Apache can serve it over HTTP.
  #
  # CN embeds VM hostname + build timestamp so a deliberate rebuild is
  # obvious in `openssl x509` — shows which cache instance signed a leaf.
  - |
    set -e
    CA_DIR=/etc/squid/ssl_cert
    if [ ! -f "$CA_DIR/ca.pem" ]; then
      mkdir -p "$CA_DIR"
      # -addext (self-contained) instead of -extensions v3_ca, which
      # silently produces a non-CA cert when /etc/ssl/openssl.cnf on the
      # installed openssl 3.x build lacks a [ v3_ca ] section. The result
      # loads but Squid rejects it ("No valid signing certificate
      # configured for HTTP_port [::]:3129") and never binds the port.
      # keyCertSign is required for ssl-bump's per-host leaf minting.
      openssl req -new -newkey rsa:2048 -sha256 -days 3650 -nodes -x509 \
        -addext "basicConstraints=critical,CA:true" \
        -addext "keyUsage=critical,digitalSignature,cRLSign,keyCertSign" \
        -addext "subjectKeyIdentifier=hash" \
        -keyout "$CA_DIR/ca.key" \
        -out   "$CA_DIR/ca.pem" \
        -subj  "/CN=yuruna-squid-cache $(hostname) $(date -u +%Y%m%dT%H%M%SZ)"
      chown -R proxy:proxy "$CA_DIR"
      chmod 700 "$CA_DIR"
      chmod 600 "$CA_DIR/ca.key"
      chmod 644 "$CA_DIR/ca.pem"
    fi
  # security_file_certgen's `-c` is create-new and errors if the DB
  # already exists, so the existence check guards re-runs. DB holds leaf
  # certs minted per SNI hostname — 4 MB is generous (each entry ~1 KB).
  #
  # The `install -d` for /var/lib/squid is NOT redundant: on Ubuntu Noble
  # the squid-openssl postinst doesn't guarantee this directory, and
  # security_file_certgen's Create() makes only the leaf `ssl_db/` dir,
  # not the parent. Without `install -d` the helper FATALs with "Cannot
  # create /var/lib/squid/ssl_db", sslcrtd children crash-loop on every
  # spawn, squid bails with "The sslcrtd_program helpers are crashing too
  # rapidly, need help!" and squid-parent blocks restart for 3600s.
  # Running as `proxy` avoids a follow-up chown and confirms write access.
  - |
    set -e
    SSL_DB=/var/lib/squid/ssl_db
    install -d -o proxy -g proxy -m 0750 /var/lib/squid
    if [ ! -d "$SSL_DB" ]; then
      sudo -u proxy /usr/lib/squid/security_file_certgen -c -s "$SSL_DB" -M 4MB
    fi
  - systemctl enable squid
  - systemctl start squid
  # Install hyperv-daemons tolerantly (see packages: note). Re-run
  # apt-get update because hyperv-daemons' linux-cloud-tools-$(uname -r)
  # dep can show up after a refresh. If it still fails, discovery falls
  # back to ARP — don't abort the rest of runcmd.
  - DEBIAN_FRONTEND=noninteractive apt-get update || true
  # Single-quoted so YAML doesn't parse `yuruna:` inside the echo as a
  # mapping key and abort runcmd with a shellify TypeError.
  - 'DEBIAN_FRONTEND=noninteractive apt-get install -y hyperv-daemons || echo "yuruna: hyperv-daemons install failed - host IP discovery will fall back to ARP"'
  # Start hv-kvp-daemon so the host can discover our IP. `|| true` because
  # the service only exists if the install above succeeded.
  - systemctl enable hv-kvp-daemon.service || true
  - systemctl start hv-kvp-daemon.service || true
  # --- Enable cachemgr.cgi monitoring ---
  # a2enmod cgi wires mod_cgi into Apache; a2enconf enables the RFC1918
  # ACL dropin. Squid's default squid.conf has `http_access allow manager
  # localhost` + `http_access deny manager`, so manager queries from
  # 127.0.0.1 (Apache) succeed while remote mgr: URLs are rejected.
  - a2enmod cgi
  - a2enconf yuruna-cachemgr
  # Publish the CA public cert at http://<cache>/yuruna-squid-ca.crt so
  # guests can fetch and trust it during install. Only the public cert
  # is copied — ca.key stays in /etc/squid/ssl_cert/. Mode 644 is
  # intentional: RFC1918 reachability is enforced at the network layer
  # (Hyper-V Default Switch), so trust distribution works without an
  # extra cachemgr-style `Require ip` dropin.
  - install -m 0644 /etc/squid/ssl_cert/ca.pem /var/www/html/yuruna-squid-ca.crt
  - systemctl enable apache2
  - systemctl restart apache2
  # --- Pre-warm the cache ---
  # security.ubuntu.com rate-limits linux-firmware (~330 MB) hard enough
  # that every cold guest install 429s on it. Pre-fetching via the local
  # proxy means squid has it before any guest asks, so the first-ever
  # install serves from cache. Pull the HWE meta too so kernel, modules-
  # extra, headers, and microcode .debs land alongside.
  #
  # Wait up to 60s for squid's listener. apt's postinst usually has it up,
  # but re-check because the preceding `squid -z` can take time on first
  # boot to initialize the 40 GB swap state.
  - |
    for i in $(seq 1 60); do
      ss -ltn 'sport = :3128' 2>/dev/null | grep -q 3128 && break
      sleep 1
    done
    # Diagnostic safety net: if squid never bound :3128, dump journal
    # into cloud-init-output.log so the operator's first
    # `grep ERROR /var/log/cloud-init-output.log` surfaces the real cause
    # (e.g. EADDRINUSE from a duplicate http_port). Otherwise the host
    # just sees "can't TCP-connect" without knowing why.
    if ! ss -ltn 'sport = :3128' 2>/dev/null | grep -q 3128; then
      echo "=== YURUNA: squid did not bind :3128 within 60s ==="
      systemctl --no-pager -l status squid || true
      journalctl --no-pager -u squid -n 80 || true
    fi
  # Only NOW route this VM's own apt through local squid — squid is
  # confirmed listening, so the self-proxy loop is safe. Writing this
  # before package install (which we did, once) makes apt try to fetch
  # squid itself through a proxy that doesn't exist yet.
  - echo 'Acquire::http::Proxy "http://127.0.0.1:3128";' > /etc/apt/apt.conf.d/99yuruna-prewarm-proxy
  - apt-get update
  # Each call: --reinstall --download-only first (forces re-fetch of
  # already-installed packages like linux-firmware); fall back to plain
  # --download-only for not-yet-installed packages (linux-generic-hwe-24.04
  # and friends). `|| true` on the fallback so one miss doesn't abort the
  # loop.
  - |
    for pkg in linux-firmware linux-generic-hwe-24.04 intel-microcode amd64-microcode firmware-sof-signed; do
      echo "=== yuruna prewarm: $pkg ==="
      apt-get install --download-only --reinstall -y "$pkg" 2>/dev/null \
        || apt-get install --download-only -y "$pkg" 2>/dev/null \
        || echo "yuruna prewarm: skipped $pkg"
    done
  # Squid now has the large .debs cached under /var/spool/squid.
  # Clear /var/cache/apt (squid's store is separate) to reclaim ~1 GB.
  - apt-get clean
  # Remove the apt proxy dropin so future apt inside this VM doesn't loop
  # through its own squid. Guests still reach squid at 3128 over network.
  - rm -f /etc/apt/apt.conf.d/99yuruna-prewarm-proxy
  # --- Flip squid into offline_mode now prewarm is done. With
  # offline_mode on, squid serves cached objects without contacting
  # origin — hit returns stored content, miss returns 504. Enables the
  # "fully disconnected if everything is cached" workflow: guests can
  # apt-install against this proxy with no internet on the host.
  #
  # Must be AFTER prewarm — with offline_mode on, a cold-cache first
  # request returns 504 and prewarm populates nothing. Dropped as a
  # separate conf.d file so an operator can refresh against origin by
  # removing the one file and running `squid -k reconfigure`.
  - |
    cat > /etc/squid/conf.d/yuruna-offline.conf << 'EOF'
    # Serve only from cache; never contact origin. Miss returns 504. To
    # refresh against origin: delete this file and `squid -k reconfigure`
    # (or `systemctl reload squid`).
    offline_mode on
    EOF
  - squid -k reconfigure
  # Single-quote the echo so YAML doesn't parse `cache:` as a mapping key.
  # cloud-init's shellify() chokes on a dict in runcmd and aborts the
  # ENTIRE runcmd phase — which happened once, leaving a VM with Apache's
  # default page, no cachemgr, no offline_mode, no monitoring even though
  # write_files and packages ran.
  - 'echo "squid-cache offline_mode ON - serving cached content only"'
  # --- Build and install squid-exporter. No apt package and no stable
  # GitHub release-asset URL, so `go install` is the reliable cross-arch
  # path: amd64 on Hyper-V, arm64 on UTM, no URL guessing. Pinned to
  # v1.10.5 for reproducibility. Runs AFTER the prewarm proxy cleanup so
  # the Go module fetch (HTTPS to proxy.golang.org + GitHub) doesn't
  # traverse squid — HTTP squid can't cache HTTPS without SSL-bump.
  - |
    export GOPATH=/root/go HOME=/root
    if /usr/bin/go install github.com/boynux/squid-exporter@v1.10.5; then
        install -m 0755 /root/go/bin/squid-exporter /usr/local/bin/squid-exporter
        echo "yuruna: squid-exporter installed at /usr/local/bin/squid-exporter"
    else
        echo "=== YURUNA: squid-exporter build failed — Grafana squid panels will stay empty until the binary is provided by hand ==="
    fi
    rm -rf /root/go
  # Reclaim ~400 MB: Go toolchain is only needed for the build above;
  # squid-exporter itself is a static binary.
  - DEBIAN_FRONTEND=noninteractive apt-get purge -y golang-go || true
  - DEBIAN_FRONTEND=noninteractive apt-get autoremove -y
  # --- Start the monitoring stack. daemon-reload picks up the
  # squid-exporter unit + grafana-server drop-in written via write_files.
  # Grafana is restarted (not just enabled) so the anonymous-Viewer env
  # vars take effect even if the deb postinst already started it.
  - systemctl daemon-reload
  - systemctl enable --now squid-exporter.service
  - systemctl enable --now prometheus.service
  - systemctl enable grafana-server.service
  - systemctl restart grafana-server.service
  # Wait for grafana-server to bind :3000 and dump journal if it doesn't.
  # On a slow first boot, grafana can take ~15s to come up after
  # `restart` returns. Without this check, a failed start only surfaces
  # when an operator tries the dashboard and gets "connection refused" —
  # by which time cloud-init logs may be rotated. Mirrors the squid:3128
  # diagnostic net so both failure modes surface the same way in
  # /var/log/cloud-init-output.log.
  - |
    for i in $(seq 1 60); do
      systemctl is-active --quiet grafana-server.service && \
        ss -ltn 'sport = :3000' 2>/dev/null | grep -q 3000 && break
      sleep 1
    done
    if ! systemctl is-active --quiet grafana-server.service; then
      echo "=== YURUNA: grafana-server did not become active within 60s ==="
      systemctl --no-pager -l status grafana-server.service || true
      journalctl --no-pager -u grafana-server.service -n 80 || true
    fi
  # --- Loki + Promtail. The proxy group exists by now (squid-openssl
  # was in `packages:`), so daemon-reload + restart picks up the
  # SupplementaryGroups=proxy drop-in written above; promtail can then
  # read /var/log/squid/access.log. Without the restart, promtail keeps
  # running with the unit definition cached at deb-postinst time (when
  # systemd may have started it before the proxy group existed) and
  # logs "permission denied" on every poll — Grafana panel stays empty.
  #
  # `install -d` (no -g, since there's no `promtail` / `loki` group —
  # see the drop-in comment) creates the per-service state dirs that
  # the debs' postinsts don't reliably create:
  #   /var/lib/promtail  — positions.yaml lives here.
  #   /var/lib/loki      — Loki's `path_prefix` from /etc/loki/config.yml.
  # Loki crashes on startup with `mkdir /var/lib/loki: permission denied`
  # if the dir doesn't exist, since /var/lib is root:root and the loki
  # user can't create new top-level entries. systemd retries 19x and
  # gives up ("Start request repeated too quickly"); promtail then
  # silently retries POST /loki/api/v1/push forever and the dashboard
  # panel stays empty. `reset-failed` clears the rate-limit before our
  # restart so the unit can come up cleanly.
  - install -d -o promtail -m 0755 /var/lib/promtail
  - install -d -o loki -m 0755 /var/lib/loki
  - systemctl daemon-reload
  - systemctl reset-failed loki.service promtail.service
  - systemctl enable --now loki.service
  - systemctl enable --now promtail.service
  - systemctl restart loki.service promtail.service
  # Verify promtail picked up the drop-in. Log a clear breadcrumb to
  # cloud-init-output.log if not — the Grafana panel emptiness is
  # otherwise silent and only surfaces hours later when an operator
  # notices "no data".
  - |
    sleep 2
    if ! systemctl show -p SupplementaryGroups promtail.service | grep -q proxy; then
      echo "=== YURUNA: promtail.service did not pick up SupplementaryGroups=proxy — Last 100 requests panel will stay empty ==="
      systemctl --no-pager -l status promtail.service || true
      journalctl --no-pager -u promtail.service -n 20 || true
    fi
  - |
    vm_ip=$(ip -4 -o addr show scope global | awk '{print $4}' | cut -d/ -f1 | head -1)
    echo "=== YURUNA monitoring ==="
    echo "  Grafana:    http://${vm_ip}:3000 (anonymous Viewer — no login required)"
    echo "  Prometheus: http://127.0.0.1:9090 (loopback only — scrape via Grafana)"
    echo "  Loki:       http://127.0.0.1:3100 (loopback only — scrape via Grafana)"
    echo "  cachemgr:   http://${vm_ip}/cgi-bin/cachemgr.cgi (raw cachemgr fallback)"
    echo "  CA cert:    http://${vm_ip}/yuruna-squid-ca.crt (trust to enable :3129 HTTPS caching)"
  # Single-quoted: the bare `: ` after "ready" makes YAML parse the
  # scalar as a mapping; shellify() gets a dict instead of a string and
