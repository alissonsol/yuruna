#cloud-config
hostname: squid-cache
# Replace the Ubuntu cloud image's default `ubuntu` user with `yuruna`.
# Listing a `users:` block WITHOUT `- default` suppresses ubuntu creation
# entirely — only the listed users land in /etc/passwd. yuruna gets:
#   - Passwordless sudo (this VM is a debug box on a private switch).
#   - The yuruna harness SSH key for passwordless `ssh yuruna@<cache-ip>`.
#   - lock_passwd: false so chpasswd below can set a known random password
#     for console fallback (vmconnect / utmctl) when cloud-init hasn't
#     finished and SSH isn't up yet.
users:
  - name: yuruna
    gecos: yuruna debug user
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    ssh_authorized_keys:
      - SSH_AUTHORIZED_KEY_PLACEHOLDER
chpasswd:
  expire: false
  users:
    - name: yuruna
      password: PASSWORD_PLACEHOLDER
      type: text
ssh_pwauth: true
