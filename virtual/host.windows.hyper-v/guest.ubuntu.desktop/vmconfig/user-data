#cloud-config
autoinstall:
  version: 1
  # apt.proxy (scoped — not top-level `proxy:`) routes only apt/apt-get
  # through the local squid-cache. Scope matters: top-level `proxy:`
  # also exports http_proxy/https_proxy into late-commands' env, which
  # previously broke `wget https://...` against proxies that refused
  # CONNECT. The block below is injected by New-VM.ps1 — includes
  # `apt: proxy:` plus a `sources_list:` override and a matching
  # `sources:` entry; New-VM.ps1 omits the whole block when no
  # squid-cache is reachable and subiquity fetches direct.
  #
  # Why this matters for kernel install: subiquity's
  # `apt-get --download-only linux-generic-hwe-24.04` runs before our
  # late-commands, so under apt-cacher-ng those went direct and
  # security.ubuntu.com's 429 periodically failed the install. apt.proxy
  # applies before the kernel step, so downloads flow through squid and
  # are cacheable across subsequent installs.
APT_PROXY_BLOCK_PLACEHOLDER
  locale: en_US.UTF-8
  keyboard:
    layout: us
  packages:
    - console-setup
    - keyboard-configuration
  identity:
    hostname: HOSTNAME_PLACEHOLDER
    username: ubuntu
    password: "HASH_PLACEHOLDER"
  storage:
    layout:
      name: lvm
  # Pin the kernel to linux-generic. Ubuntu Desktop 24.04 defaults to
  # HWE meta linux-generic-hwe-24.04 in noble-updates — NOT on the
  # installer cdrom. During curtin's install_kernel the target chroot's
  # sources.list still only references file:/cdrom (the earlier
  # network-mirror rewrite doesn't reach the chroot yet), so
  # `apt-get install --download-only linux-generic-hwe-24.04` returns
  # "Unable to locate package" and fails the install. linux-generic
  # ships on the cdrom, so the step succeeds without network.
  kernel:
    package: linux-generic
  ssh:
    allow-pw: true
  # ssh.install-server intentionally omitted: the Desktop ISO ships no
  # openssh-server on /cdrom, and subiquity's target apt only sees
  # file:/cdrom during install (the http mirror it configures applies
  # post-install). install-server: true fails with "openssh-server has no
  # installation candidate". Installed via first-boot cloud-init below —
  # by then 99yuruna-apt-cache routes the download through the proxy.
  # Pass-through cloud-init for the INSTALLED target. Subiquity doesn't
  # parse this block; it copies it to the installed system for first
  # boot. Top-level ssh_authorized_keys attaches to the default user
  # (ubuntu) after subiquity commits identity — avoids earlier failure
  # modes where ssh.authorized-keys or raw SSH-related late-commands
  # silently broke identity application.
  user-data:
    ssh_authorized_keys:
      - SSH_AUTHORIZED_KEY_PLACEHOLDER
    package_update: true
    packages:
      - openssh-server
  late-commands:
    # --- Apt cache: persist proxy into the installed system ---
    # Belt-and-suspenders with autoinstall.apt.proxy: subiquity writes
    # an apt proxy config into the target when apt.proxy is set, but we
    # explicitly write 99yuruna-apt-cache so (a) the file name is
    # predictable for debugging and (b) behavior is unchanged if
    # subiquity's apt-persistence logic drifts.
    # New-VM.ps1 substitutes CACHING_PROXY_URL_PLACEHOLDER with the
    # detected URL or "". On "", [ -n "" ] is false and the file isn't
    # created. On hit, every post-install apt-get (openssh-server,
    # test-workload, VS Code, .NET SDK, Kubernetes packages) flows
    # through the cache.
    - |
      if [ -n "CACHING_PROXY_URL_PLACEHOLDER" ]; then
        echo 'Acquire::http::Proxy "CACHING_PROXY_URL_PLACEHOLDER";' > /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        chmod 0644 /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        # --- HTTPS caching opt-in: trust the squid-cache CA, point
        # Acquire::https::Proxy at the ssl-bump listener on :3129.
        # Best-effort: any failure (CA fetch, trust-update) leaves the
        # plain-HTTP proxy in place and HTTPS apt goes direct — same
        # behavior as pre-ssl-bump, so an older cache build without the
        # CA endpoint degrades gracefully instead of aborting.
        CACHE_HOST=$(echo "CACHING_PROXY_URL_PLACEHOLDER" | sed -E 's|^https?://([^:/]+).*|\1|')
        mkdir -p /target/usr/local/share/ca-certificates
        if wget --no-cache --tries=3 --timeout=15 -q \
            -O /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt \
            "http://${CACHE_HOST}/yuruna-squid-ca.crt"; then
          chmod 0644 /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
          curtin in-target --target=/target -- update-ca-certificates
          echo "Acquire::https::Proxy \"http://${CACHE_HOST}:3129\";" >> /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        else
          echo "yuruna: CA fetch from ${CACHE_HOST} failed - HTTPS apt will bypass the cache (HTTP caching unaffected)." >&2
          rm -f /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
        fi
      fi
    # --- Cap systemd-networkd-wait-online so first boot doesn't hang ---
    # See guest.ubuntu.server/vmconfig/user-data for full rationale.
    # Ubuntu 24.04 default is "wait for ALL interfaces routable, no
    # timeout"; on Hyper-V Default Switch the IPv6 path eventually
    # resolves but adds minutes. --any --timeout=15 caps it.
    - mkdir -p /target/etc/systemd/system/systemd-networkd-wait-online.service.d
    - |
      cat > /target/etc/systemd/system/systemd-networkd-wait-online.service.d/override.conf << 'EOF'
      [Service]
      ExecStart=
      ExecStart=/lib/systemd/systemd-networkd-wait-online --any --timeout=15
      EOF
    # --- Security: user account ---
    - curtin in-target --target=/target -- passwd --expire ubuntu
    # --- SSH: install yuruna test-harness key for the ubuntu user ---
    # Single curtin-in-target, mirroring the passwd --expire pattern.
    # Previous attempts (autoinstall.ssh.authorized-keys, multi-line raw
    # shell late-commands) silently broke subiquity's identity (empty
    # /etc/shadow). This form runs after identity is committed.
    - curtin in-target --target=/target -- bash -c 'install -d -m 700 -o ubuntu -g ubuntu /home/ubuntu/.ssh && echo "SSH_AUTHORIZED_KEY_PLACEHOLDER" > /home/ubuntu/.ssh/authorized_keys && chmod 600 /home/ubuntu/.ssh/authorized_keys && chown ubuntu:ubuntu /home/ubuntu/.ssh/authorized_keys'
    # --- Sudo: passwordless for the ubuntu user (test harness) ---
    # Lets the SSH-driven workload call /automation/fetch-and-execute.sh
    # with sudo (no TTY, no askpass under BatchMode). 0440 per sudoers.d.
    - curtin in-target --target=/target -- bash -c 'echo "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/90-yuruna-ubuntu && chmod 440 /etc/sudoers.d/90-yuruna-ubuntu && chown root:root /etc/sudoers.d/90-yuruna-ubuntu'
    # --- System: disable swap ---
    - sed -i '/ swap / s/^/#/' /target/etc/fstab
    - curtin in-target --target=/target -- systemctl mask swap.target
    # --- System: disable MOTD ---
    - chmod -x /target/etc/update-motd.d/*
    - mkdir -p /target/etc/default && test -f /target/etc/default/motd-news && sed -i 's/^ENABLED=1/ENABLED=0/' /target/etc/default/motd-news || echo 'ENABLED=0' > /target/etc/default/motd-news
    # --- GNOME: skip initial setup ---
    - curtin in-target --target=/target -- mkdir -p /etc/skel/.config
    - echo 'yes' > /target/etc/skel/.config/gnome-initial-setup-done
    - curtin in-target --target=/target -- mkdir -p /home/ubuntu/.config
    - echo 'yes' > /target/home/ubuntu/.config/gnome-initial-setup-done
    - curtin in-target --target=/target -- chown -R ubuntu:ubuntu /home/ubuntu/.config
    # --- GNOME: auto-open terminal on login ---
    - curtin in-target --target=/target -- mkdir -p /etc/xdg/autostart
    - |
      cat > /target/etc/xdg/autostart/open-terminal.desktop << 'DESKTOP'
      [Desktop Entry]
      Type=Application
      Name=Open Terminal
      Exec=gnome-terminal
      X-GNOME-Autostart-enabled=true
      NoDisplay=true
      DESKTOP
    # --- IBus: stub ibus-daemon to avoid the gdm greeter IM race ---
    # On Ubuntu 24.04 + GNOME 46, the gdm greeter's gnome-shell spawns
    # two ibus-daemon instances back-to-back (the second with "-r --xim"
    # for Xwayland XIM). The replace handshake orphans gnome-shell's
    # InputContext D-Bus proxy; subsequent key presses call
    # ProcessKeyEvent on the dead path, get UnknownMethod, and are
    # swallowed by the IM filter. Login fields look focused but accept
    # no input; Enter/Tab/Escape and tty switches still work (they
    # bypass IM). GTK_IM_MODULE/QT_IM_MODULE verified NOT to help:
    # gnome-shell's Wayland IM uses libibus directly, bypassing GTK.
    # Only reliable fix is to prevent ibus-daemon from running at all:
    # divert the real binary and symlink to /bin/true so gnome-shell's
    # exec returns immediately. Key events then reach text entries via
    # libinput → mutter → clutter. For yuruna test VMs (ASCII passwords
    # only) losing IBus is a non-issue. dpkg-divert survives apt upgrades.
    - curtin in-target --target=/target -- dpkg-divert --local --add --rename /usr/bin/ibus-daemon
    - curtin in-target --target=/target -- ln -sf /bin/true /usr/bin/ibus-daemon
    # --- GNOME: enable automatic timezone (requires dconf) ---
    - mkdir -p /target/etc/dconf/db/local.d
    - |
      cat > /target/etc/dconf/db/local.d/00-timezone << 'DCONF'
      [org/gnome/desktop/datetime]
      automatic-timezone=true

      [org/gnome/system/location]
      enabled=true
      DCONF
    # --- GDM greeter: never blank the display ---
    # ubuntu.desktop.update.sh disables idle/lock for the ubuntu USER,
    # but that profile does NOT apply to the GDM greeter, which runs
    # under the `gdm` system-db profile. With default idle-delay the
    # greeter blanks after ~3 min, screen captures return black, OCR
    # finds no text, and Test-Workload step 1 ("Not listed?") times out
    # even though the greeter renders fine if anyone touches the VM.
    # /etc/dconf/db/gdm.d/ + dconf update is Canonical's documented way
    # to override greeter settings at install time.
    - mkdir -p /target/etc/dconf/db/gdm.d
    - |
      cat > /target/etc/dconf/db/gdm.d/99-yuruna-no-idle << 'DCONF'
      [org/gnome/desktop/session]
      idle-delay=uint32 0

      [org/gnome/settings-daemon/plugins/power]
      sleep-inactive-ac-type='nothing'
      sleep-inactive-battery-type='nothing'
      idle-dim=false
      power-button-action='nothing'

      [org/gnome/desktop/screensaver]
      lock-enabled=false
      idle-activation-enabled=false
      DCONF
    - curtin in-target --target=/target -- dconf update
    # --- GRUB: nomodeset to prevent blank-screen-on-reboot (x86_64 KMS race) ---
    # On x86_64/Hyper-V, the simpledrm -> hyperv_drm KMS handoff races
    # intermittently (LP #2064815). Apply nomodeset at install time so the
    # FIRST installed boot is already safe. ubuntu.desktop.update.sh is idempotent.
    - |
      if [ -f /target/etc/default/grub ] && ! grep -q 'nomodeset' /target/etc/default/grub; then
        sed -i -E 's|^GRUB_CMDLINE_LINUX_DEFAULT="([^"]*)"|GRUB_CMDLINE_LINUX_DEFAULT="\1 nomodeset"|; s|="  *|="|' /target/etc/default/grub
        curtin in-target --target=/target -- update-grub
      fi
    # --- System: denylist hv_balloon to prevent console messages ---
    - |
      cat > /target/etc/modprobe.d/denylist-hv-balloon.conf << 'MODPROBE'
      blacklist hv_balloon
      MODPROBE
    # --- Network: download fetch-and-execute utility ---
    - mkdir -p /target/automation
    - wget --no-cache -O /target/automation/fetch-and-execute.sh "https://raw.githubusercontent.com/alissonsol/yuruna/refs/heads/main/automation/fetch-and-execute.sh"
    - curtin in-target --target=/target -- chmod +x /automation/fetch-and-execute.sh
    # --- Network: timezone detection via IP geolocation and NTP ---
    - curtin in-target --target=/target -- timedatectl set-ntp true
    - curtin in-target --target=/target -- bash -c 'command -v wget >/dev/null 2>&1 && TZ=$(wget -qO - --timeout=5 "http://ip-api.com/line?fields=timezone") && [ -n "$TZ" ] && timedatectl set-timezone "$TZ" || echo "Yuruna => Timezone sync failed (check wget, network, or API)" >&2'
