#cloud-config
autoinstall:
  version: 1
  # apt.proxy (scoped — not top-level `proxy:`) routes only apt/apt-get
  # through the local squid-cache. Scope matters: top-level `proxy:`
  # also exports http_proxy/https_proxy into late-commands' env, which
  # previously broke `wget https://...` against proxies that refused
  # CONNECT. The block below is injected by New-VM.ps1 — includes
  # `apt: proxy:` plus `sources_list:` and a matching `sources:` entry;
  # New-VM.ps1 omits the whole block when no squid-cache is reachable.
  #
  # Why Server ISO instead of Desktop: the Desktop 24.04 ISO ships
  # /etc/apt/sources.list.d/ubuntu.sources with a cdrom-only entry, and
  # the cdrom carries no kernel meta-package — curtin's install_kernel
  # fails with "Unable to locate package linux-generic[-hwe-24.04]". The
  # Server ISO ships a network-configured ubuntu.sources AND
  # linux-generic on the cdrom, so autoinstall completes cleanly. The
  # guest stays in text mode — no ubuntu-desktop, no GDM. The Test-Start
  # sequence drives the text-mode login prompt directly.
APT_PROXY_BLOCK_PLACEHOLDER
  locale: en_US.UTF-8
  keyboard:
    layout: us
  packages:
    - console-setup
    - keyboard-configuration
  identity:
    hostname: HOSTNAME_PLACEHOLDER
    username: ubuntu
    password: "HASH_PLACEHOLDER"
  storage:
    layout:
      name: lvm
  ssh:
    # Server cdrom ships openssh-server, so install-server: true works
    # (Desktop ISO defers this to first-boot cloud-init).
    install-server: true
    allow-pw: true
    authorized-keys:
      - SSH_AUTHORIZED_KEY_PLACEHOLDER
  # Pass-through cloud-init for the INSTALLED target. Subiquity copies
  # this block to the installed system; cloud-init consumes it on first
  # boot. Used ONLY to silence the default SSH-fingerprint console
  # emission — same category as the hv_balloon denylist below.
  #   * no_ssh_fingerprints: true  — disables cc_ssh_authkey_fingerprints
  #     (the "Authorized keys from /home/ubuntu/.ssh/authorized_keys"
  #     ci-info table).
  #   * ssh.emit_keys_to_console: false — disables cc_keys_to_console
  #     (the "BEGIN SSH HOST KEY FINGERPRINTS" + "BEGIN SSH HOST KEY KEYS"
  #     dumps via /dev/kmsg, which the getty tty1 echoes regardless of
  #     login state and races first-boot login). Distinct from
  #     autoinstall.ssh above (subiquity's installer-side SSH config).
  user-data:
    no_ssh_fingerprints: true
    ssh:
      emit_keys_to_console: false
  # Server autoinstall normally presents a confirmation prompt;
  # interactive-sections: [] disables every interactive step so the
  # install runs fully unattended — no "Install" click / Tab dance
  # that the Desktop ISO required.
  interactive-sections: []
  late-commands:
    # --- Apt cache: persist proxy into the installed system ---
    # Belt-and-suspenders with autoinstall.apt.proxy: subiquity writes
    # an apt proxy config into the target when apt.proxy is set, but
    # we explicitly write 99yuruna-apt-cache so (a) the file name is
    # predictable for debugging and (b) behavior is unchanged if
    # subiquity's apt-persistence logic drifts.
    - |
      if [ -n "CACHING_PROXY_URL_PLACEHOLDER" ]; then
        echo 'Acquire::http::Proxy "CACHING_PROXY_URL_PLACEHOLDER";' > /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        chmod 0644 /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        # --- HTTPS caching opt-in: trust the squid-cache CA, point
        # Acquire::https::Proxy at the ssl-bump listener on :3129.
        # Best-effort: any failure (CA fetch, trust-update) leaves the
        # plain-HTTP proxy in place and HTTPS apt goes direct — same
        # behavior as pre-ssl-bump, so an older cache without the CA
        # endpoint degrades gracefully instead of aborting.
        CACHE_HOST=$(echo "CACHING_PROXY_URL_PLACEHOLDER" | sed -E 's|^https?://([^:/]+).*|\1|')
        mkdir -p /target/usr/local/share/ca-certificates
        if wget --no-cache --tries=3 --timeout=15 -q \
            -O /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt \
            "http://${CACHE_HOST}/yuruna-squid-ca.crt"; then
          chmod 0644 /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
          curtin in-target --target=/target -- update-ca-certificates
          echo "Acquire::https::Proxy \"http://${CACHE_HOST}:3129\";" >> /target/etc/apt/apt.conf.d/99yuruna-apt-cache
        else
          echo "yuruna: CA fetch from ${CACHE_HOST} failed - HTTPS apt will bypass the cache (HTTP caching unaffected)." >&2
          rm -f /target/usr/local/share/ca-certificates/yuruna-squid-ca.crt
        fi
      fi
    # --- Cap systemd-networkd-wait-online so first boot doesn't hang ---
    # Ubuntu 24.04's networkd-wait-online defaults to "wait for ALL
    # interfaces routable, no timeout". On Hyper-V Default Switch the
    # IPv6 path eventually resolves, just slowly — visible as:
    #   Job systemd-networkd-wait-online.service/start running ([TIME] / no limit)
    # Cloud-init's first-boot run transitively depends on
    # network-online.target, so slow wait-online delays first login by
    # minutes. --any --timeout=15 = "ANY interface routable OR 15s,
    # whichever first" — what the harness actually needs.
    - mkdir -p /target/etc/systemd/system/systemd-networkd-wait-online.service.d
    - |
      cat > /target/etc/systemd/system/systemd-networkd-wait-online.service.d/override.conf << 'EOF'
      [Service]
      ExecStart=
      ExecStart=/lib/systemd/systemd-networkd-wait-online --any --timeout=15
      EOF
    # --- Security: user account ---
    - curtin in-target --target=/target -- passwd --expire ubuntu
    # --- Sudo: passwordless for the ubuntu user (test harness) ---
    - curtin in-target --target=/target -- bash -c 'echo "ubuntu ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/90-yuruna-ubuntu && chmod 440 /etc/sudoers.d/90-yuruna-ubuntu && chown root:root /etc/sudoers.d/90-yuruna-ubuntu'
    # --- System: disable swap ---
    - sed -i '/ swap / s/^/#/' /target/etc/fstab
    - curtin in-target --target=/target -- systemctl mask swap.target
    # --- System: disable MOTD ---
    - chmod -x /target/etc/update-motd.d/*
    - mkdir -p /target/etc/default && test -f /target/etc/default/motd-news && sed -i 's/^ENABLED=1/ENABLED=0/' /target/etc/default/motd-news || echo 'ENABLED=0' > /target/etc/default/motd-news
    # --- System: denylist hv_balloon to prevent console messages ---
    # hv_balloon spams the console with harmless memory-pressure
    # messages that pollute OCR.
    - |
      cat > /target/etc/modprobe.d/denylist-hv-balloon.conf << 'MODPROBE'
      blacklist hv_balloon
      MODPROBE
    # --- Console: order getty after cloud-final to prevent login race ---
    # cloud-init's "running 'modules: final'" / "finished" lifecycle
    # banners reach the console via /dev/kmsg (kernel-style
    # `[ 44.688245] cloud-init[1065]:` timestamps), unconditionally —
    # there is no cloud-config knob to silence them, unlike the
    # cc_keys_to_console / cc_ssh_authkey_fingerprints pair muted via
    # user-data above. On first boot those banners land AFTER getty
    # has already drawn `login:`, so the operator's typed username
    # and login(1)'s subsequent `Password:` prompt get split across
    # the cloud-init dump and OCR cannot match `Password:`. Ordering
    # getty@.service After=cloud-final.service holds the login prompt
    # until cloud-init final is finished, so the console settles
    # before login. Drop-in lives on the template (getty@.service.d/)
    # so it covers tty1 plus any other getty instance the
    # systemd-getty-generator spawns. After= is ordering only — if
    # cloud-final ever fails to start, getty still comes up.
    - mkdir -p /target/etc/systemd/system/getty@.service.d
    - |
      cat > /target/etc/systemd/system/getty@.service.d/override.conf << 'EOF'
      [Unit]
      After=cloud-final.service
      EOF
    # --- Yuruna host coordinates: written for the dev iteration loop ---
    # New-VM.ps1 substitutes the placeholders below at provision time.
    # Guest scripts read /etc/yuruna/host.env to prefer the local status
    # server over GitHub. /etc/hosts gives a stable name (yuruna-host)
    # that survives DHCP renumbering inside the guest's session.
    # Caveat: Hyper-V Default Switch IP changes across host reboots —
    # rebuild the guest if Test-YurunaHost.ps1 fails after a host reboot.
    - mkdir -p /target/etc/yuruna
    - |
      cat > /target/etc/yuruna/host.env << 'EOF'
      YURUNA_HOST_IP=YURUNA_HOST_IP_PLACEHOLDER
      YURUNA_HOST_PORT=YURUNA_HOST_PORT_PLACEHOLDER
      EOF
    - |
      grep -q yuruna-host /target/etc/hosts || \
        echo "YURUNA_HOST_IP_PLACEHOLDER yuruna-host" >> /target/etc/hosts
    # --- wget no_proxy: belt-and-braces for the host status-server probe ---
    # subiquity's apt:proxy can leak as http_proxy into the installed
    # system. Without no_proxy, an in-guest fetch-and-execute.sh that
    # lacks --no-proxy would route the /livecheck probe through the
    # squid-cache, which cannot reach the host's private NAT address,
    # and silently fall through to GitHub.
    - |
      cat >> /target/etc/wgetrc << 'EOF'
      no_proxy = YURUNA_HOST_IP_PLACEHOLDER
      EOF
    # --- Network: download fetch-and-execute utility ---
    # Try the host status server first (fast, local, devloop-friendly)
    # and fall back to raw.githubusercontent.com if it is not reachable.
    - mkdir -p /target/automation
    - |
      wget --no-cache --timeout=5 -O /target/automation/fetch-and-execute.sh "http://YURUNA_HOST_IP_PLACEHOLDER:YURUNA_HOST_PORT_PLACEHOLDER/yuruna-repo/automation/fetch-and-execute.sh" || \
      wget --no-cache -O /target/automation/fetch-and-execute.sh "https://raw.githubusercontent.com/alissonsol/yuruna/refs/heads/main/automation/fetch-and-execute.sh"
    - curtin in-target --target=/target -- chmod +x /automation/fetch-and-execute.sh
    # --- Network: timezone detection via IP geolocation and NTP ---
    - curtin in-target --target=/target -- timedatectl set-ntp true
    - curtin in-target --target=/target -- bash -c 'command -v wget >/dev/null 2>&1 && TZ=$(wget -qO - --timeout=5 "http://ip-api.com/line?fields=timezone") && [ -n "$TZ" ] && timedatectl set-timezone "$TZ" || echo "Yuruna => Timezone sync failed (check wget, network, or API)" >&2'
